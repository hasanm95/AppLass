---
import Section from "@/components/common/Section.astro";
import { getFomoGenData } from "@/constants/fomogen-data";
import {
  ShoppingCart,
  Timer,
  ShoppingBag,
  TrendingUp,
  ShieldCheck,
  HelpCircle,
} from "lucide-react";
import type { LucideIcon } from "lucide-react";
import { Image } from "astro:assets";

const ICON_MAP: Record<string, LucideIcon> = {
  ShoppingCart,
  Timer,
  ShoppingBag,
  TrendingUp,
  ShieldCheck,
};

import socialProofUiImg from "@/assets/apps/fomogen/social-proof-ui.png";
import scarcityUiImg from "@/assets/apps/fomogen/scarcity-ui.png";
import stickyCartUiImg from "@/assets/apps/fomogen/sticky-cart-ui.png";
import shippingBarUiImg from "@/assets/apps/fomogen/shipping-bar-ui.png";

const fomoData = getFomoGenData();
const labels = fomoData.labels;

const imageMap = [socialProofUiImg, scarcityUiImg, stickyCartUiImg, shippingBarUiImg];
const features = fomoData.features.map((feature, idx) => ({
  ...feature,
  imageSrc: imageMap[idx] || undefined
}));
---

<Section id="features" className="relative bg-white py-24 md:py-32">
  <div class="section-container relative z-10">
    <div class="mb-20 text-center lg:text-left">
      <span class="mb-6 block text-[10px] font-black tracking-[0.2em] text-green-600 uppercase">
        {labels?.platformPillars || "Platform Pillars"}
      </span>
      <h2 class="mb-10 text-4xl leading-[0.95] font-bold tracking-tight text-slate-900 md:text-5xl lg:text-8xl">
        {labels?.everythingYouNeed || "Everything You Need."}
        <br />
        <span class="text-slate-300">{labels?.nothingYouDont || "Nothing You Don't."}</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-12 lg:gap-24">
      {features.map((feature, idx) => {
        const Icon = ICON_MAP[feature.iconName] || HelpCircle;
        const isEven = idx % 2 === 0;

        const finalImageSrc = feature.imageSrc;

        return (
          <div
            class={`flex flex-col items-center gap-12 lg:flex-row lg:gap-24 ${
              isEven ? "" : "lg:flex-row-reverse"
            }`}
          >
            {/* Visual Section */}
            <div class="relative w-full flex-1">
              {finalImageSrc ? (
                <div class="relative aspect-video overflow-hidden rounded-4xl border border-slate-100 bg-slate-50 shadow-2xl md:rounded-[3rem]">
                  <Image
                    src={finalImageSrc}
                    alt={`${feature.title} - ${feature.subtitle} [App Protocol Feature]`}
                    width={800}
                    height={450}
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                </div>
              ) : (
                <div class="flex aspect-video items-center justify-center rounded-4xl border border-green-100 bg-green-50/30 md:rounded-[3rem]">
                  <Icon className="h-24 w-24 text-green-600 opacity-20" />
                </div>
              )}

              {/* Decorative elements */}
              <div
                class={`absolute -right-6 -bottom-6 h-24 w-24 rounded-full bg-green-500/10 blur-2xl ${isEven ? "" : "right-auto -left-6"}`}
              />
            </div>

            {/* Content Section */}
            <div class="flex-1 text-center lg:text-left">
              <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-2xl border border-green-100 bg-green-50 text-green-600 shadow-sm">
                <Icon className="h-8 w-8" />
              </div>

              <h3 class="mb-4 text-3xl font-bold tracking-tight text-slate-900 md:text-5xl">
                {feature.title}
              </h3>

              <h4 class="mb-6 text-xl font-bold text-green-600 italic">
                {feature.subtitle}
              </h4>

              <p class="text-lg leading-relaxed font-medium text-slate-500 md:text-xl">
                {feature.description}
              </p>

              <div class="mt-10 flex items-center justify-center gap-3 lg:justify-start">
                <div class="h-2 w-2 animate-pulse rounded-full bg-green-500" />
                <span class="text-xs font-black tracking-widest text-slate-400 uppercase">
                  {feature.highlight}
                </span>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Section>
