---
import Section from "@/components/common/Section.astro";
import { Button } from "@/components/ui/button";
import { FOMOGEN_DATA } from "@/constants/fomogen-data";
import { Check } from "lucide-react";

type PricingTranslation = {
  subtitle: string;
  tiers: { name: string; price: string; period: string; description: string; features: string[]; cta: string; }[];
};

import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { getDictionary } from "@/i18n/get-dictionary";

const lang = getLangFromUrl(Astro.url);
const dict = await getDictionary(lang as any);
const t = useTranslations(dict);
const translations = t('fomogen.pricing') as PricingTranslation;
const labels = t('fomogen.labels');
---

<Section className="relative bg-white py-24 md:py-32">
  {/* Background Vignette */}
  <div class="pointer-events-none absolute bottom-0 left-0 h-[800px] w-full bg-linear-to-t from-green-50/80 to-transparent" />

  <div class="section-container relative z-10 max-w-7xl mx-auto">
    <div class="mb-16 text-center md:mb-20">
      <span class="mb-6 inline-block rounded-full bg-green-50 px-4 py-1.5 text-[10px] font-black tracking-[0.2em] text-green-600 uppercase ring-1 ring-green-500/20">
        {FOMOGEN_DATA.pricing.subtitle}
      </span>
      <h2 class="mb-6 text-4xl leading-[0.95] font-bold tracking-tight text-slate-900 md:text-6xl lg:text-7xl">
        {FOMOGEN_DATA.pricing.title}
      </h2>
      <p class="text-lg md:text-xl text-slate-600 mb-8 max-w-2xl mx-auto font-medium">
        {FOMOGEN_DATA.pricing.description}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4 mb-24">
      {FOMOGEN_DATA.pricing.tiers.map((baseTier, idx) => {
        const tier = translations?.tiers?.[idx] || baseTier;
        return (
        <div
          class={`group relative flex flex-col rounded-4xl p-8 backdrop-blur-xl transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl md:rounded-[2.5rem] md:p-10 ${
            baseTier.highlighted
              ? "border-green-400 bg-white shadow-[0_40px_100px_-20px_rgba(33,196,93,0.15)] ring-4 ring-green-50"
              : "border-white/40 bg-white shadow-xl"
          }`}
        >
          {baseTier.highlighted && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-green-600 px-6 py-1.5 text-[10px] font-black tracking-widest text-white uppercase shadow-lg shadow-green-200">
              {labels?.recommended || "Recommended"}
            </div>
          )}

          <div class="mb-8">
            <h3 class="text-xl font-bold tracking-tight text-slate-900 md:text-2xl">
              {tier.name}
            </h3>
            <p class="mt-2 text-sm font-medium text-slate-500 min-h-[40px]">
              {tier.description}
            </p>
          </div>

          <div class="mb-8">
            <span class="text-4xl font-black text-slate-900 md:text-5xl tracking-tight">
              {tier.price}
            </span>
            <span class="ml-2 text-[10px] font-bold tracking-widest text-slate-400 uppercase">
              {tier.period}
            </span>
            {baseTier.subLabel && (
              <p class="text-xs text-green-600 font-bold mt-3 tracking-wide bg-green-50 inline-block px-3 py-1 rounded-full">
                {baseTier.subLabel}
              </p>
            )}
          </div>

          <Button
            className={`mb-10 h-14 w-full rounded-xl text-base font-bold transition-all duration-300 active:scale-95 md:h-16 md:rounded-2xl md:text-lg ${
              baseTier.highlighted
                ? "bg-slate-900 text-white shadow-xl shadow-slate-200 hover:bg-black"
                : "bg-slate-100 text-slate-900 hover:bg-slate-200"
            }`}
            asChild
          >
            <a href={FOMOGEN_DATA.cta.shopifyUrl}>{tier.cta}</a>
          </Button>

          <div class="grow space-y-5 border-t border-slate-100 pt-8">
            <p class="text-[10px] font-black uppercase text-slate-400 tracking-[0.2em]">
              {labels?.featuresIncluded || "Features Included"}
            </p>
            <ul class="space-y-4">
              {baseTier.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <Check className="mt-0.5 h-4 w-4 shrink-0 text-green-600" />
                  <span class="text-sm font-medium text-slate-600 leading-snug">
                    {feature}
                  </span>
                </li>
              ))}
              {baseTier.limitations?.map((limit) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-slate-300 text-[10px] font-bold text-slate-400 italic">
                    i
                  </span>
                  <span class="text-sm italic text-slate-400 flex-1 leading-snug">
                    {limit}
                  </span>
                </li>
              ))}
            </ul>
          </div>

        </div>
        );
      })}
    </div>

  </div>
</Section>
