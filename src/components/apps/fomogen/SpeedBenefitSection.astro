---
import Section from "@/components/common/Section.astro";
import { FOMOGEN_DATA } from "@/constants/fomogen-data";
import { Zap, AlertTriangle, ShieldCheck } from "lucide-react";

import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { getDictionary } from "@/i18n/get-dictionary";

const lang = getLangFromUrl(Astro.url);
const dict = await getDictionary(lang as any);
const t = useTranslations(dict);
const speedBenefit = t('fomogen.speedBenefit') || FOMOGEN_DATA.speedBenefit;
const labels = t('fomogen.labels');
---

<Section className="relative overflow-hidden bg-slate-50 py-24 md:py-32">
  {/* Subtle Grid Background */}
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.03]"
    style={{
      backgroundImage: "radial-gradient(#000 1px, transparent 1px)",
      backgroundSize: "40px 40px",
    }}
  />

  <div class="section-container relative z-10">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
      <div>
        <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-red-50 px-4 py-2 text-[10px] font-black tracking-widest text-red-600 uppercase">
          <AlertTriangle className="h-3 w-3" />
          {labels?.efficiencyWarning || "Efficiency Warning"}
        </div>

        <h2 class="text-4xl leading-[0.95] font-bold tracking-tight text-slate-900 md:text-5xl lg:text-7xl">
          {speedBenefit.title}
        </h2>

        <p class="mt-8 text-xl leading-relaxed font-medium text-slate-500">
          {speedBenefit.body}
        </p>

        <div class="mt-10 rounded-2xl border border-red-100 bg-red-50/30 p-8 md:p-10">
          <p class="text-lg font-black text-red-700 italic">
            {speedBenefit.fact}
          </p>
        </div>
      </div>

      <div class="relative">
        <div class="relative z-10 flex flex-col gap-6 rounded-[2.5rem] border border-white/60 bg-white/40 p-8 shadow-2xl backdrop-blur-xl md:p-12">
          <div class="flex items-start gap-6">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-slate-900 text-white">
              <Zap className="h-6 w-6" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900">
                {labels?.theStruggle || "The Struggle"}
              </h3>
              <p class="mt-2 font-medium text-slate-500">
                {speedBenefit.struggle}
              </p>
            </div>
          </div>

          <div class="h-px w-full bg-slate-100" />

          <div class="flex items-start gap-6">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-green-600 text-white">
              <ShieldCheck className="h-6 w-6" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900">
                {labels?.theSolution || "The Solution"}
              </h3>
              <p class="mt-2 font-medium text-slate-500">
                {speedBenefit.solution}
              </p>
            </div>
          </div>
        </div>

        {/* Decorative Pulse */}
        <div class="absolute top-1/2 left-1/2 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-green-100/30 blur-3xl" />
      </div>
    </div>
  </div>
</Section>
