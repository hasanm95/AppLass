---
import Section from "@/components/common/Section.astro";
import { localize } from "@/i18n/localize";
import { Check, X, AlertTriangle } from "lucide-react";
---

<Section className="relative bg-black py-24 md:py-32">
  <div class="section-container relative z-10">
    <div class="mb-16 text-center">
      <span class="mb-6 block text-[10px] font-black tracking-[0.2em] text-green-500 uppercase">
        {localize("Comparison")}
      </span>
      <h2 class="text-3xl leading-tight font-bold tracking-tight text-white md:text-5xl">
        {localize("ScreenVeil vs. The Alternatives.")}
      </h2>
    </div>

    <div class="mx-auto max-w-5xl overflow-x-auto rounded-3xl border border-green-500/20 bg-slate-900/50 p-1 md:p-8 shadow-2xl">
      <table class="w-full text-left text-sm text-slate-300 md:text-base">
        <thead class="bg-slate-950/50 text-xs text-slate-400 font-bold uppercase md:text-sm">
          <tr>
            <th scope="col" class="px-6 py-4 rounded-tl-2xl">Feature</th>
            <th scope="col" class="px-6 py-4 text-green-400">ScreenVeil</th>
            <th scope="col" class="px-6 py-4">YouTube Premium</th>
            <th scope="col" class="px-6 py-4 rounded-tr-2xl">Grayscale Filter Apps</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-white/5 bg-slate-900/40">
            <th scope="row" class="px-6 py-4 font-medium text-white">Works across all apps</th>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> Yes</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><X className="h-4 w-4 text-red-500" /> YouTube only</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> Yes</div></td>
          </tr>
          <tr class="border-b border-white/5 bg-slate-900/20">
            <th scope="row" class="px-6 py-4 font-medium text-white">AMOLED pixel savings</th>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> True black</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><X className="h-4 w-4 text-red-500" /> No</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><AlertTriangle className="h-4 w-4 text-yellow-500" /> Partial</div></td>
          </tr>
          <tr class="border-b border-white/5 bg-slate-900/40">
            <th scope="row" class="px-6 py-4 font-medium text-white">Pocket/touch lock</th>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> Yes</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><X className="h-4 w-4 text-red-500" /> No</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><X className="h-4 w-4 text-red-500" /> No</div></td>
          </tr>
          <tr class="border-b border-white/5 bg-slate-900/20">
            <th scope="row" class="px-6 py-4 font-medium text-white">Cost</th>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> Free</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><X className="h-4 w-4 text-red-500" /> $13.99/month</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> Free</div></td>
          </tr>
          <tr class="border-b border-white/5 bg-slate-900/40">
            <th scope="row" class="px-6 py-4 font-medium text-white">Internet required</th>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> None</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><X className="h-4 w-4 text-red-500" /> Required</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> None</div></td>
          </tr>
          <tr class="bg-slate-900/20 rounded-b-2xl">
            <th scope="row" class="px-6 py-4 font-medium text-white rounded-bl-2xl">Zero permissions</th>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><Check className="h-4 w-4 text-green-500" /> Overlay only</div></td>
            <td class="px-6 py-4"><div class="flex items-center gap-2"><X className="h-4 w-4 text-red-500" /> Full account</div></td>
            <td class="px-6 py-4 rounded-br-2xl"><div class="flex items-center gap-2"><AlertTriangle className="h-4 w-4 text-yellow-500" /> Varies</div></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</Section>
