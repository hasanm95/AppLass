---
import Section from "@/components/common/Section.astro";
import { localize } from "@/i18n/localize";
---
<Section className="relative border-b shadow-sm border-slate-200 bg-[#FBFBFA] py-8 border-t">
  <div class="section-container relative z-10 w-full max-w-7xl">
    <div class="flex flex-col items-center justify-center gap-8 md:flex-row md:justify-around lg:gap-16">
      <div class="text-center">
        <p class="text-3xl font-black text-slate-900 md:text-4xl">2.4h</p>
        <p class="mt-2 text-xs font-bold tracking-widest text-slate-500 uppercase">{localize("Focus Reclaimed Daily")}</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-black text-slate-900 md:text-4xl">100%</p>
        <p class="mt-2 text-xs font-bold tracking-widest text-slate-500 uppercase">{localize("On-Device — No Cloud")}</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-black text-slate-900 md:text-4xl">0ms</p>
        <p class="mt-2 text-xs font-bold tracking-widest text-slate-500 uppercase">{localize("Blocking Latency")}</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-black text-slate-900 md:text-4xl">Zero</p>
        <p class="mt-2 text-xs font-bold tracking-widest text-slate-500 uppercase">{localize("Telemetry")}</p>
      </div>
    </div>
  </div>
</Section>
