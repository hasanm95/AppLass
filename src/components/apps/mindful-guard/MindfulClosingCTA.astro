---
import Section from "@/components/common/Section.astro";
import { localize } from "@/i18n/localize";
import { LinkButton } from "@/components/ui/link-button";
---

<Section className="relative bg-slate-100 py-24 md:py-32">
  <div class="section-container relative z-10">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-6 text-4xl leading-tight font-black tracking-tight text-slate-900 md:text-5xl lg:text-6xl">
        {localize("Download Mindful Guard Free.")}
      </h2>
      <p class="mb-10 text-lg leading-relaxed font-medium text-slate-600 md:text-xl">
        {localize("The only Android focus app that blocks distractions without watching you do it. 100% offline. Zero telemetry. Built for privacy absolutists and deep work practitioners.")}
      </p>
      
      <div class="flex flex-col items-center justify-center gap-6">
        <LinkButton
          size="lg"
          className="h-16 rounded-2xl bg-blue-600 px-12 text-lg font-bold text-white shadow-xl shadow-blue-500/30 transition-all duration-500 hover:-translate-y-1 hover:bg-blue-700 active:translate-y-0"
          href="https://play.google.com/store/apps/details?id=com.anonymous.mindfulguard"
          target="_blank"
          rel="noopener noreferrer"
        >
          {localize("Get it on Google Play")}
        </LinkButton>
        <p class="text-sm font-bold text-slate-500">
          {localize("Free to download • No internet required • Zero data collection")}
        </p>
      </div>

      <div class="mt-20 pt-10 border-t border-slate-300 text-center">
        <p class="text-slate-500 font-medium">
            {localize("Explore:")} <a href="/" class="text-blue-600 hover:text-blue-800 transition-colors underline underline-offset-4 font-bold">Home</a> • <a href="/apps/screenveil" class="text-blue-600 hover:text-blue-800 transition-colors underline underline-offset-4 font-bold">ScreenVeil</a> • <a href="/apps/fomogen" class="text-blue-600 hover:text-blue-800 transition-colors underline underline-offset-4 font-bold">FomoGen</a>
        </p>
      </div>
    </div>
  </div>
</Section>
