---
import Section from "@/components/common/Section.astro";
import { getMindfulGuardData } from "@/constants/mindful-guard-data";

const mindfulData = getMindfulGuardData();
const dict = mindfulData.logic;
const labels = mindfulData.labels;
---

<Section id="logic" className="border-y border-slate-200 bg-[#FBFBFA]">
  <div class="section-container">
    <div class="flex flex-col gap-24 lg:flex-row lg:items-center">
      <div class="flex-1 lg:max-w-xl">
        <span class="mb-6 block font-mono text-[10px] font-bold tracking-[0.3em] text-[#064E3B] uppercase">
          {labels.technicalLogic}
        </span>
        <h2 class="mb-8 text-5xl leading-tight font-black tracking-tighter text-slate-950 md:text-6xl">
          {dict.title}
        </h2>
        <p class="mb-12 text-xl leading-relaxed font-medium text-slate-600">
          {dict.description}
        </p>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div class="border-l-2 border-[#064E3B] bg-emerald-50/30 p-6">
            <p class="mb-2 font-mono text-[10px] font-bold tracking-widest text-[#064E3B] uppercase">
              {labels.systemLevel}
            </p>
            <p class="leading-tight font-bold text-slate-900">
              {labels.interceptsDistractions}
            </p>
          </div>
          <div class="border-l-2 border-slate-900 bg-slate-50 p-6">
            <p class="mb-2 font-mono text-[10px] font-bold tracking-widest text-slate-900 uppercase">
              {labels.cognitiveLoad}
            </p>
            <p class="leading-tight font-bold text-slate-900">
              {labels.zeroWillpowerArchitecture}
            </p>
          </div>
        </div>
      </div>

      <div class="relative w-full lg:flex-1">
        <div class="relative aspect-4/3 overflow-hidden border-2 border-slate-950 bg-white p-8 shadow-[12px_12px_0px_0px_rgba(6,78,59,0.1)]">
          {/* Technical Blueprint Grid */}
          <div
            class="pointer-events-none absolute inset-0 opacity-[0.05]"
            style={{
              backgroundImage:
                "linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px)",
              backgroundSize: "32px 32px",
            }}
          />

          <div class="relative flex h-full w-full flex-col items-center justify-center border border-slate-100 bg-slate-50/50">
            {/* Abstract Data Flow Visual */}
            <div class="relative flex h-64 w-full max-w-md items-center justify-center">
              <div class="absolute h-full w-[2px] bg-slate-200" />
              <div class="absolute h-[2px] w-full bg-slate-200" />

              {/* Nodes */}
              <div class="relative z-10 flex h-full w-full items-center justify-around">
                <div class="flex h-16 w-16 items-center justify-center border-2 border-slate-950 bg-white font-mono text-xs font-bold">
                  {labels.input}
                </div>
                <div class="flex h-24 w-24 items-center justify-center border-2 border-[#064E3B] bg-[#064E3B] font-mono text-xs font-bold text-white shadow-[6px_6px_0_0_rgba(6,78,59,0.2)]">
                  {labels.filter}
                </div>
                <div class="flex h-16 w-16 items-center justify-center border-2 border-slate-950 bg-white font-mono text-xs font-bold">
                  {labels.focus}
                </div>
              </div>

              {/* Flow Lines */}
              <div class="absolute top-1/2 left-[20%] h-1 w-[15%] border-t-2 border-dashed border-slate-400" />
              <div class="absolute top-1/2 left-[45%] h-1 w-[15%] border-t-2 border-dashed border-[#064E3B]" />
            </div>

            <div class="mt-8 font-mono text-[9px] font-bold tracking-[0.4em] text-slate-400 uppercase">
              {labels.logicalFlow}
            </div>
          </div>
        </div>

        {/* Background Fragment */}
        <div class="absolute -top-6 -right-6 -bottom-6 -left-6 -z-10 border border-slate-100 bg-[#FAFBFD]" />
      </div>
    </div>
  </div>
</Section>
