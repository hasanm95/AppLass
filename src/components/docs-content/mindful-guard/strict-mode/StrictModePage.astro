---
import { Lock, Timer, ShieldAlert } from "lucide-react";
import { localize } from "@/i18n/localize";


const features = [
  {
    title: localize("No-Bypass Architecture"),
    description: localize("Bypassing the block is mathematically impossible during an active session."),
    icon: Lock
  },
  {
    title: localize("Scheduled Enforcement"),
    description: localize("Pre-plan your focus blocks for the week. Once they start, the firewall is absolute."),
    icon: Timer
  },
  {
    title: localize("Cognitive Firewall"),
    description: localize("Intercepts distraction attempts at the system level before they reach your conscious mind."),
    icon: ShieldAlert
  }
];
---

<div class="space-y-12">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-slate-900 uppercase">
      {localize("Guide #02")}
    </span>
    <h1 class="text-4xl font-black text-slate-900 md:text-5xl">
      {localize("Strict Logic Mode")}<span class="text-slate-300">.</span>
    </h1>
    <p class="mt-6 max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("The core of the cognitive firewall. Enforce zero-bypass focus sessions that cannot be interrupted.")}
    </p>
  </header>

  <div class="prose prose-slate max-w-none">
    <h2 class="text-2xl font-black text-slate-900">{localize("How it works")}</h2>
    <p class="text-lg font-medium text-slate-500">
      {localize("Strict Mode locks your chosen settings for a set duration. It prevents anyone (including you) from uninstalling the app or changing the blocking schedule until the timer expires.")}
    </p>
  </div>

  <div class="grid gap-8">
    {features.map((feature) => {
      const Icon = feature.icon;
      return (
        <div class="flex gap-6 rounded-3xl border border-slate-50 bg-white p-8">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-slate-50">
            <Icon className="h-6 w-6 text-blue-600" />
          </div>
          <div>
            <h3 class="mb-2 text-xl font-black text-slate-900">{feature.title}</h3>
            <p class="font-medium text-slate-500">{feature.description}</p>
          </div>
        </div>
      );
    })}
  </div>

  <div class="rounded-[2.5rem] border border-red-50 bg-red-50/10 p-12">
    <p class="mb-4 font-black tracking-widest text-red-600 uppercase">
      {localize("Warning")}
    </p>
    <h3 class="mb-4 text-2xl font-black text-slate-900">
      {localize("No Recovery Possible")}
    </h3>
    <p class="max-w-lg text-lg leading-relaxed font-medium text-slate-500">
      {localize("Strict Mode is designed to be permanent for the duration you set. There is no \"Emergency Unlock\" by design. Use with intention.")}
    </p>
  </div>
</div>
