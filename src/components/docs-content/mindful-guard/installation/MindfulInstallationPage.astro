---
import { Zap, Download, ShieldCheck } from "lucide-react";
import { localize } from "@/i18n/localize";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const steps = [
  {
    number: "01",
    title: localize("Download from Play Store"),
    description: localize("Visit the official Google Play Store link to download the latest stable release of Mindful Guard."),
    icon: Download
  },
  {
    number: "02",
    title: localize("Grant Usage Access"),
    description: localize("To monitor and block distracting apps, Mindful Guard requires the 'Usage Access' permission. This is processed entirely on-device."),
    icon: Zap
  },
  {
    number: "03",
    title: localize("Battery Exemption"),
    description: localize("Crucial: Disable battery optimization for Mindful Guard to ensure Android's Power Management doesn't kill the blocking process."),
    icon: ShieldCheck
  }
];
---

<div class="space-y-12">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-slate-900 uppercase">
      {localize("Guide #01")}
    </span>
    <h1 class="text-4xl font-black text-slate-900 md:text-5xl">
      {localize("Installation Guide")}<span class="text-slate-300">.</span>
    </h1>
    <p class="mt-6 max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("Step-by-step instructions for deploying the cognitive firewall to your Android device.")}
    </p>
  </header>

  <section class="space-y-8">
    <h2 class="text-2xl font-black text-slate-900">{localize("Deployment Steps")}</h2>

    <div class="grid gap-8">
      {steps.map((step) => {
        const Icon = step.icon;
        return (
          <div class="group flex gap-8 rounded-3xl border border-slate-50 bg-white p-8 transition-all hover:border-slate-200 hover:shadow-xl">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-slate-50 text-xl font-black text-slate-900 transition-colors group-hover:bg-blue-50 group-hover:text-blue-600">
              {step.number}
            </div>
            <div>
              <div class="mb-2 flex items-center gap-3">
                <Icon className="h-6 w-6 text-blue-600" />
                <h3 class="text-xl font-black text-slate-900">{step.title}</h3>
              </div>
              <p class="leading-relaxed font-medium text-slate-500">
                {step.description}
              </p>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <div class="rounded-[2.5rem] border border-slate-100 bg-[#FAFBFD] p-12">
    <h3 class="mb-4 text-2xl font-black text-slate-900">
      {localize("Ready to block?")}
    </h3>
    <p class="mb-8 max-w-lg text-lg leading-relaxed font-medium text-slate-500">
      {localize("Once installed, head over to the Strict Logic Mode guide to learn how to enforce your deep work sessions.")}
    </p>
  </div>
</div>
