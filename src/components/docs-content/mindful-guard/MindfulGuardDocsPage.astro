---
import { Button } from "@/components/ui/button";
import { localePath } from "@/i18n/utils";
import { localize } from "@/i18n/localize";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
---
<div class="space-y-20">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-slate-900 uppercase">
      {localize("Neural Architecture Guide")}
    </span>
    <h1 class="text-display mb-6 text-slate-900">
      {localize("Documentation")}<span class="text-slate-300">.</span>
    </h1>
    <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("Mindful Guard is a cognitive firewall for Android. Deploy strict logic to prevent digital distractions with zero telemetry and total privacy.")}
    </p>
  </header>

  <div class="grid gap-6 sm:grid-cols-2">
    <a
      href={localePath(lang, "/docs/mindful-guard/installation")}
      class="group rounded-3xl border border-slate-100 bg-white p-8 transition-all duration-500 hover:border-slate-500/20 hover:shadow-2xl hover:shadow-slate-500/5 focus:ring-2 focus:ring-slate-500 focus:outline-none"
    >
      <h3 class="mb-3 text-lg font-black text-slate-900 transition-colors group-hover:text-slate-600">
        ⚡ {localize("Installation")}
      </h3>
      <p class="font-medium text-slate-500 transition-colors group-hover:text-slate-600">
        {localize("Deploy the cognitive firewall to your Android device today.")}
      </p>
    </a>
    <a
      href={localePath(lang, "/docs/mindful-guard/strict-mode")}
      class="group rounded-3xl border border-slate-100 bg-white p-8 transition-all duration-500 hover:border-slate-500/20 hover:shadow-2xl hover:shadow-slate-500/5 focus:ring-2 focus:ring-slate-500 focus:outline-none"
    >
      <h3 class="mb-3 text-lg font-black text-slate-900 transition-colors group-hover:text-slate-600">
        🔒 {localize("Strict Mode")}
      </h3>
      <p class="font-medium text-slate-500 transition-colors group-hover:text-slate-600">
        {localize("Learn how to lock down your device for maximum focus.")}
      </p>
    </a>
  </div>

  {/* Support CTA */}
  <div class="rounded-[2.5rem] border border-slate-100 bg-[#FAFBFD] p-12">
    <h3 class="mb-4 text-2xl font-black text-slate-900">{localize("Need help?")}</h3>
    <p class="mb-8 max-w-lg text-lg leading-relaxed font-medium text-slate-500">
      {localize("Mindful Guard is engineered for privacy absolutists. If you need technical assistance, our logic lab is here to help.")}
    </p>
    <Button
      className="rounded-xl bg-slate-900 font-bold hover:bg-slate-800"
      client:idle
    >
      <a href="mailto:support@applass.com">{localize("Contact Support")}</a>
    </Button>
  </div>
</div>
