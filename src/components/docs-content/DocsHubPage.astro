---
import { Zap, Shield, Smartphone, ArrowRight } from "lucide-react";
import { localePath } from "@/i18n/utils";
import { localize } from "@/i18n/localize";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const systems = [
  {
    id: "fomogen",
    name: "FOMO Gen",
    tagline: localize("Conversion Engineering"),
    icon: Zap,
    description: localize("High-performance Shopify growth loops and social psychology modules."),
    link: localePath(lang, "/docs/fomogen"),
    color: "blue",
  },
  {
    id: "mindful",
    name: "Mindful Guard",
    tagline: localize("Digital Discipline"),
    icon: Shield,
    description: localize("Advanced heuristic filters for focus and intentional device usage."),
    link: localePath(lang, "/docs/mindful-guard"),
    color: "slate",
  },
  {
    id: "screenveil",
    name: "ScreenVeil",
    tagline: localize("Background Architecture"),
    icon: Smartphone,
    description: localize("Low-level background process management for Android environments."),
    link: localePath(lang, "/docs/screenveil"),
    color: "blue",
  },
];
---
<div class="space-y-16">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
      {localize("Knowledge Base")}
    </span>
    <h1 class="text-display mb-6 text-slate-900">
      {localize("Logic Systems")}<span class="text-slate-300">.</span>
    </h1>
    <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("The central repository for AppLass engineering. Choose a logic system to view its technical implementation and deployment protocols.")}
    </p>
  </header>

  <div class="grid gap-6">
    {systems.map((system) => {
      const Icon = system.icon;
      return (
        <a
          href={system.link}
          class={`group relative flex flex-col gap-6 rounded-[2.5rem] border border-slate-100 bg-white p-10 transition-all duration-500 hover:border-blue-500/20 hover:shadow-2xl hover:shadow-blue-500/5 ${
            system.link === "#" ? "pointer-events-none opacity-60" : ""
          }`}
        >
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-50 transition-colors group-hover:bg-blue-50">
                <Icon className="h-6 w-6 text-blue-600" aria-hidden="true" />
              </div>
              <div>
                <h3 class="text-xl font-black text-slate-900">
                  {system.name}
                </h3>
                <p class="text-xs font-black tracking-widest text-blue-600 uppercase">
                  {system.tagline}
                </p>
              </div>
            </div>
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-50 text-slate-400 transition-all group-hover:bg-blue-600 group-hover:text-white">
              <ArrowRight className="h-5 w-5" aria-hidden="true" />
            </div>
          </div>

          <p class="max-w-xl text-lg leading-relaxed font-medium text-slate-500">
            {system.description}
          </p>
        </a>
      );
    })}
  </div>
</div>
