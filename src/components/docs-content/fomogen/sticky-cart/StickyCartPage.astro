---
import { localize } from "@/i18n/localize";

---
<div class="space-y-20">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
      {localize("Utility Module")}
    </span>
    <h1 class="text-display mb-6 text-slate-900">
      {localize("Sticky Cart Bar")}<span class="text-slate-300">.</span>
    </h1>
    <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("Frictionless throughflow. Maintain persistent access to the conversion trigger as visitors navigate deep product narratives.")}
    </p>
  </header>

  <div class="space-y-24">
    {/* Mechanism */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Mechanism of Action")}
      </h2>
      <div class="rounded-[2.5rem] border border-slate-100 bg-[#FAFBFD] p-10 lg:p-14">
        <p class="max-w-3xl text-lg leading-relaxed font-medium text-slate-600">
          {localize("The Sticky Module monitors the vertical scroll parity of the viewport. Once the primary 'Add to Cart' button exits the visible frame, the secondary sticky bar is injected into the fixed Z-layer, ensuring the purchase vector remains a single tap away.")}
        </p>
      </div>
    </section>

    {/* Configuration Matrix */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Configuration Matrix")}
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="group rounded-[2.5rem] border border-slate-100 bg-white p-10 shadow-xl shadow-slate-200/20 transition-all hover:border-blue-100 hover:shadow-blue-500/5">
          <h3 class="mb-4 text-xl font-black text-slate-900">{localize("Spatial Anchors")}</h3>
          <p class="mb-8 text-lg leading-relaxed font-medium text-slate-500">
            {localize("Deploy to the top (Desktop dominance) or bottom (Thumb-friendly mobile reach) of the viewport.")}
          </p>
          <div class="inline-block rounded-full bg-slate-50 px-4 py-1 text-xs font-black tracking-wider text-slate-400 uppercase transition-colors group-hover:bg-blue-50 group-hover:text-blue-600">
            {localize("Anchor: Fixed")}
          </div>
        </div>

        <div class="group rounded-[2.5rem] border border-slate-100 bg-white p-10 shadow-xl shadow-slate-200/20 transition-all hover:border-blue-100 hover:shadow-blue-500/5">
          <h3 class="mb-4 text-xl font-black text-slate-900">{localize("Trigger Threshold")}</h3>
          <p class="mb-8 text-lg leading-relaxed font-medium text-slate-500">
            {localize("Define the precise scroll offset (e.g., 300px) required to activate the sticky transition logic.")}
          </p>
          <div class="inline-block rounded-full bg-slate-50 px-4 py-1 text-xs font-black tracking-wider text-slate-400 uppercase transition-colors group-hover:bg-blue-50 group-hover:text-blue-600">
            {localize("Trigger: Kinetic")}
          </div>
        </div>
      </div>
    </section>

    {/* Variant Logic */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Variant Synchronization")}
      </h2>
      <div class="overflow-hidden rounded-3xl border border-slate-100 bg-white">
        <table class="w-full border-collapse text-left">
          <thead>
            <tr class="border-b border-slate-100 bg-slate-50/50">
              <th class="px-8 py-5 text-[10px] font-black tracking-widest text-slate-500 uppercase">
                {localize("Feature")}
              </th>
              <th class="px-8 py-5 text-[10px] font-black tracking-widest text-slate-500 uppercase">
                {localize("Execution")}
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <tr class="transition-colors hover:bg-slate-50/50">
              <td class="px-8 py-5 text-sm font-bold text-slate-900">
                {localize("Live Selection")}
              </td>
              <td class="px-8 py-5 text-sm font-medium text-slate-500">
                {localize("Allows selection of SKU variants directly from the fixed bar.")}
              </td>
            </tr>
            <tr class="transition-colors hover:bg-slate-50/50">
              <td class="px-8 py-5 text-sm font-bold text-slate-900">
                {localize("Price Parity")}
              </td>
              <td class="px-8 py-5 text-sm font-medium text-slate-500">
                {localize("Dynamically updates valuation as variants or quantities shift.")}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    {/* Mobile Protocol */}
    <div class="rounded-[2.5rem] bg-slate-900 p-12 text-white">
      <h4 class="mb-4 text-sm font-black tracking-widest text-blue-400 uppercase">
        {localize("Mobile Protocol")}
      </h4>
      <p class="text-xl leading-relaxed font-medium opacity-80">
        {localize("For handheld optimization, we strictly recommend the")} <strong>{localize("Bottom")}</strong> {localize("anchor. This aligns with modern 'reach design' standards, placing the buy trigger directly under the user's natural thumb resting position.")}
      </p>
    </div>
  </div>
</div>
