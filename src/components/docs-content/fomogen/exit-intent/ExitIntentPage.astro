---
import { localize } from "@/i18n/localize";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const features = [
  {
    title: localize("Kinetic Exit"),
    desc: localize("Standard mouse tracking for desktop environments. Detects trajectory and speed towards browser UI."),
    meta: localize("Platform: Desktop")
  },
  {
    title: localize("Mobile Inactivity"),
    desc: localize("Detects session stagnation or sudden back-press gestures on handheld devices."),
    meta: localize("Platform: Mobile")
  }
];

const controls = [
  {
    name: localize("Frequency"),
    behavior: localize("Limit display to once per session to maintain UX integrity.")
  },
  {
    name: localize("Cart Threshold"),
    behavior: localize("Suppress/Show based on real-time cart valuation.")
  }
];
---

<div class="space-y-20">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
      {localize("Retention Module")}
    </span>
    <h1 class="text-display mb-6 text-slate-900">
      {localize("Exit Intent Popups")}<span class="text-slate-300">.</span>
    </h1>
    <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("Precision recovery. Capture fleeing traffic with high-context offers before they sever the session.")}
    </p>
  </header>

  <div class="space-y-24">
    {/* How It Works */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Mechanism of Action")}
      </h2>
      <div class="rounded-[2.5rem] border border-slate-100 bg-[#FAFBFD] p-10 lg:p-14">
        <p class="max-w-3xl text-lg leading-relaxed font-medium text-slate-600">
          {localize("The FOMO Engine monitors kinetic and behavioral data points in real-time. When a qualifying exit vector is detected — such as radial mouse velocity towards the URL bar or rapid mobile scroll-up — the intervention layer is activated.")}
        </p>
      </div>
    </section>

    {/* Trigger Matrix */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Trigger Matrix")}
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        {features.map((feature) => (
          <div class="group rounded-[2.5rem] border border-slate-100 bg-white p-10 shadow-xl shadow-slate-200/20 transition-all hover:border-blue-100 hover:shadow-blue-500/5">
            <h3 class="mb-4 text-xl font-black text-slate-900">{feature.title}</h3>
            <p class="mb-8 text-lg leading-relaxed font-medium text-slate-500">
              {feature.desc}
            </p>
            <div class="inline-block rounded-full bg-slate-50 px-4 py-1 text-xs font-black tracking-wider text-slate-400 uppercase transition-colors group-hover:bg-blue-50 group-hover:text-blue-600">
              {feature.meta}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Targeting Controls */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Targeting Controls")}
      </h2>
      <div class="overflow-hidden rounded-3xl border border-slate-100 bg-white shadow-xl shadow-slate-200/20">
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-left">
            <thead>
              <tr class="border-b border-slate-100 bg-slate-50/50">
                <th class="px-8 py-5 text-[10px] font-black tracking-widest text-slate-500 uppercase">
                  {localize("Control")}
                </th>
                <th class="px-8 py-5 text-[10px] font-black tracking-widest text-slate-500 uppercase">
                  {localize("Behavior")}
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              {controls.map((c) => (
                <tr class="transition-colors hover:bg-slate-50/50">
                  <td class="px-8 py-5 text-sm font-bold text-slate-900">
                    {c.name}
                  </td>
                  <td class="px-8 py-5 text-sm font-medium text-slate-500">
                    {c.behavior}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* Optimization Note */}
    <div class="rounded-[2.5rem] bg-slate-900 p-12 text-white">
      <h4 class="mb-4 text-sm font-black tracking-widest text-blue-400 uppercase">
        {localize("Optimization Note")}
      </h4>
      <p class="text-xl leading-relaxed font-medium opacity-80">
        {localize("Since mouse exit does not apply to tactile interfaces, ensure you enable")} <strong>{localize("Mobile Scroll Trigger")}</strong> {localize("or")} <strong>{localize("Inactivity Detection")}</strong> {localize("to capture handheld traffic.")}
      </p>
    </div>
  </div>
</div>
