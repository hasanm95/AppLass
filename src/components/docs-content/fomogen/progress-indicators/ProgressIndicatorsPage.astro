---
import { localize } from "@/i18n/localize";

const features = [
  {
    title: localize("Threshold Logic"),
    desc: localize("Set precise financial milestones (e.g., $50.00 for shipping). Syncs directly with Shopify shipping zone parameters."),
    meta: localize("Logic: Currency Delta")
  },
  {
    title: localize("Dynamic Messaging"),
    desc: localize("Interpolate values directly into the UI. 'Add {amount} more' updates instantly upon cart mutation."),
    meta: localize("Logic: Template Engine")
  }
];
---

<div class="space-y-20">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
      {localize("Incentive Module")}
    </span>
    <h1 class="text-display mb-6 text-slate-900">
      {localize("Progress Indicators")}<span class="text-slate-300">.</span>
    </h1>
    <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("Gamified checkout throughput. Increase average order value (AOV) by visualizing progress toward value-based milestones.")}
    </p>
  </header>

  <div class="space-y-24">
    {/* Logic */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Mechanism of Action")}
      </h2>
      <div class="rounded-[2.5rem] border border-slate-100 bg-[#FAFBFD] p-10 lg:p-14">
        <p class="mb-12 text-lg leading-relaxed font-medium text-slate-600">
          {localize("The Progress Module monitors the Shopify cart object in real-time. As the valuation delta narrows between current cart state and the target milestone, the visual indicator provides kinetic feedback, triggering the \"goal-gradient effect\" in consumer psychology.")}
        </p>

        <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-xl shadow-slate-200/10 lg:p-10">
          <div class="mb-6 flex items-center justify-between">
            <span class="text-sm font-black tracking-widest text-slate-400 uppercase">
              {localize("Live Simulation")}
            </span>
            <span class="text-sm font-black text-blue-600">
              {localize("$15.00 Remaining")}
            </span>
          </div>
          <div class="h-4 w-full overflow-hidden rounded-full bg-slate-100">
            <div
              class="h-full bg-blue-600 transition-all duration-1000"
              style={{ width: "75%" }}
            ></div>
          </div>
          <p class="mt-6 text-center text-lg font-black text-slate-900">
            {localize("Add $15.00 more for")} <span class="text-blue-600">{localize("FREE SHIPPING!")}</span> 🚚
          </p>
        </div>
      </div>
    </section>

    {/* Configuration Matrix */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Configuration Matrix")}
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        {features.map((feature) => (
          <div class="group rounded-[2.5rem] border border-slate-100 bg-white p-10 shadow-xl shadow-slate-200/20 transition-all hover:border-blue-100 hover:shadow-blue-500/5">
            <h3 class="mb-4 text-xl font-black text-slate-900">{feature.title}</h3>
            <p class="mb-8 text-lg leading-relaxed font-medium text-slate-500">
              {feature.desc}
            </p>
            <div class="inline-block rounded-full bg-slate-50 px-4 py-1 text-xs font-black tracking-wider text-slate-400 uppercase transition-colors group-hover:bg-blue-50 group-hover:text-blue-600">
              {feature.meta}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Operational Warning */}
    <div class="rounded-[2.5rem] bg-slate-900 p-12 text-white">
      <h4 class="mb-4 text-sm font-black tracking-widest text-blue-400 uppercase">
        {localize("Technical Requirement")}
      </h4>
      <p class="text-xl leading-relaxed font-medium opacity-80">
        {localize("This module is a")} <strong>{localize("visual communication layer")}</strong>. {localize("You must independently configure your Free Shipping rates or Discount logic in the Shopify Admin panel to ensure financial reconciliation at checkout.")}
      </p>
    </div>
  </div>
</div>
