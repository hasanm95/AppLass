---
import { localize } from "@/i18n/localize";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const features = [
  {
    title: localize("Temporal Windows"),
    desc: localize("Calculate sales volume for Today, This Week, or All-Time. Automatically switches to broader windows if daily volume is low."),
    meta: localize("Logic: Time-Series")
  },
  {
    title: localize("Visual Semantics"),
    desc: localize("Choose between Pill or Box layouts. Modern rounded aesthetics or traditional structured presentation styles."),
    meta: localize("Logic: UI Variants")
  }
];

const intelligence = [
  {
    title: localize("Minimum Threshold"),
    desc: localize("Intelligent suppression. The badge remains hidden until a statistically significant volume is reached (e.g., 5+ sales).")
  },
  {
    title: localize("Smart Rounding"),
    desc: localize("High-volume normalization. Large numbers are formatted (e.g., '2.5k+') to ensure a clean, authoritative UI.")
  }
];
---

<div class="space-y-20">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
      {localize("Trust Module")}
    </span>
    <h1 class="text-display mb-6 text-slate-900">
      {localize("Social Proof Badges")}<span class="text-slate-300">.</span>
    </h1>
    <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("Aggregate validation. Display high-level conversion statistics to provide immediate credibility to first-time visitors.")}
    </p>
  </header>

  <div class="space-y-24">
    {/* Mechanism */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Mechanism of Action")}
      </h2>
      <div class="rounded-[2.5rem] border border-slate-100 bg-[#FAFBFD] p-10 lg:p-14">
        <p class="max-w-3xl text-lg leading-relaxed font-medium text-slate-600">
          {localize("The Badge Module aggregates conversion event clusters over defined temporal windows. By surfacing the volume of peer participation (e.g., '127 people bought this today'), the engine builds instantaneous product-level authority.")}
        </p>
      </div>
    </section>

    {/* Feature Matrix */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Configuration Matrix")}
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        {features.map((feature) => (
          <div class="group rounded-[2.5rem] border border-slate-100 bg-white p-10 shadow-xl shadow-slate-200/20 transition-all hover:border-blue-100 hover:shadow-blue-500/5">
            <h3 class="mb-4 text-xl font-black text-slate-900">{feature.title}</h3>
            <p class="mb-8 text-lg leading-relaxed font-medium text-slate-500">
              {feature.desc}
            </p>
            <div class="inline-block rounded-full bg-slate-50 px-4 py-1 text-xs font-black tracking-wider text-slate-400 uppercase transition-colors group-hover:bg-blue-50 group-hover:text-blue-600">
              {feature.meta}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Data Intelligence */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Data Intelligence")}
      </h2>
      <ul class="space-y-6">
        {intelligence.map((item) => (
          <li class="flex gap-6 rounded-4xl border border-slate-100 p-8">
            <span class="font-black text-blue-600">/</span>
            <div>
              <h4 class="font-black text-slate-900">{item.title}</h4>
              <p class="font-medium text-slate-500">
                {item.desc}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </section>

    {/* Efficiency Tip */}
    <div class="rounded-[2.5rem] bg-slate-900 p-12 text-white">
      <h4 class="mb-4 text-sm font-black tracking-widest text-blue-400 uppercase">
        {localize("Conversion Strategy")}
      </h4>
      <p class="text-xl leading-relaxed font-medium opacity-80">
        {localize("Combine badges with")} <strong>{localize("Purchase Notifications")}</strong>. {localize("The notification creates an initial visual hook, while the badge provides a persistent evidence-based anchor for the duration of the page session.")}
      </p>
    </div>
  </div>
</div>
