---
import { localize } from "@/i18n/localize";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const features = [
  {
    title: localize("Fixed Date"),
    desc: localize("Synced to a specific calendar event. Ideal for global moments like Black Friday or seasonal clearance."),
    meta: localize("Logic: Global Timestamp")
  },
  {
    title: localize("Evergreen"),
    desc: localize("Personalized 1:1 urgency. The timer initiates upon the first session and persists across subpages."),
    meta: localize("Logic: Session-Based")
  }
];

const priorities = [
  {
    num: "01",
    title: localize("Pinned"),
    desc: localize("Manual overrides that bypass all auto-resolution.")
  },
  {
    num: "02",
    title: localize("Specific"),
    desc: localize("Variant-level timers beat global store-wide banners.")
  },
  {
    num: "03",
    title: localize("Fixed"),
    desc: localize("Calendar events generally take precedence over personal.")
  }
];

const positions = [
  {
    title: localize("Sticky Top Bar"),
    desc: localize("Global persistence. Follows the user throughout the conversion tunnel.")
  },
  {
    title: localize("Inline Product"),
    desc: localize("Direct scarcity. Nested near the CTA to drive immediate cart additions.")
  }
];
---

<div class="space-y-20">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
      {localize("Conversion Module")}
    </span>
    <h1 class="text-display mb-6 text-slate-900">
      {localize("Countdown Timers")}<span class="text-slate-300">.</span>
    </h1>
    <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("Engineered urgency. Deploy high-fidelity countdowns for flash sales, product drops, and localized sessions.")}
    </p>
  </header>

  <div class="space-y-24">
    {/* Timer Types */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Timer Types")}
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        {features.map((feature) => (
          <div class="group rounded-[2.5rem] border border-slate-100 bg-white p-10 shadow-xl shadow-slate-200/20 transition-all hover:border-blue-100 hover:shadow-blue-500/5">
            <h3 class="mb-4 text-xl font-black text-slate-900">{feature.title}</h3>
            <p class="mb-8 text-lg leading-relaxed font-medium text-slate-500">
              {feature.desc}
            </p>
            <div class="inline-block rounded-full bg-slate-50 px-4 py-1 text-xs font-black tracking-wider text-slate-400 uppercase transition-colors group-hover:bg-blue-50 group-hover:text-blue-600">
              {feature.meta}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Priority Logic */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Priority Intelligence")}
      </h2>
      <div class="rounded-[2.5rem] border border-slate-100 bg-[#FAFBFD] p-10 lg:p-14">
        <p class="mb-10 text-lg font-medium text-slate-600">
          {localize("When multiple temporal rules collide, the FOMO Engine resolves them using a weighted priority matrix:")}
        </p>
        <div class="grid gap-8 md:grid-cols-3">
          {priorities.map((item) => (
            <div>
              <span class="mb-4 block text-4xl font-black text-slate-200">
                {item.num}
              </span>
              <h4 class="mb-2 font-black text-slate-900">{item.title}</h4>
              <p class="leading-snug font-medium text-slate-500">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Deployment Positions */}
    <section>
      <h2 class="mb-8 text-2xl font-black text-slate-900">
        {localize("Deployment Positions")}
      </h2>
      <ul class="space-y-6">
        {positions.map((item) => (
          <li class="flex gap-6 rounded-4xl border border-slate-100 p-8">
            <span class="font-black text-blue-600">/</span>
            <div>
              <h4 class="font-black text-slate-900">{item.title}</h4>
              <p class="font-medium text-slate-500">
                {item.desc}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </section>

    {/* Efficiency Tip */}
    <div class="rounded-[2.5rem] bg-slate-900 p-12 text-white">
      <h4 class="mb-4 text-sm font-black tracking-widest text-blue-400 uppercase">
        {localize("Conversion Protocol")}
      </h4>
      <p class="text-xl leading-relaxed font-medium opacity-80">
        {localize("Use")} <strong>{localize("Evergreen")}</strong> {localize("timers (e.g., 15 minutes) on abandoned cart sequences or welcome flows to force immediate decision-making from new acquisitions.")}
      </p>
    </div>
  </div>
</div>
