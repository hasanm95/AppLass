---
import { BatteryLow, Zap } from "lucide-react";
import { localize } from "@/i18n/localize";

const stats = [
  {
    title: localize("Max Battery Saved"),
    value: "63%",
    description: localize("Maximum display-related power reduction at full brightness."),
    icon: BatteryLow
  },
  {
    title: localize("Pixel Latency"),
    value: "0ms",
    description: localize("Instantaneous pixel shutdown for maximum efficiency."),
    icon: Zap
  }
];
---

<div class="space-y-12">
  <header>
    <span class="mb-4 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
      {localize("Technical Reference")}
    </span>
    <h1 class="text-4xl font-black text-slate-900 md:text-5xl">
      {localize("AMOLED Efficiency")}<span class="text-slate-300">.</span>
    </h1>
    <p class="mt-6 max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {localize("The physics of battery conservation. Why True Black pixels are the ultimate power-saving hack.")}
    </p>
  </header>

  <section class="space-y-8">
    <h2 class="text-2xl font-black text-slate-900">
      {localize("Power Draw Analysis")}
    </h2>
    <p class="text-lg font-medium text-slate-500">
      {localize("On OLED and AMOLED displays, each pixel is its own light source. By displaying \"True Black,\" ScreenVeil instructs pixels to turn completely off.")}
    </p>

    <div class="grid gap-6 md:grid-cols-2">
      {stats.map((stat) => {
        const Icon = stat.icon;
        return (
          <div class="rounded-[2.5rem] border border-slate-100 bg-white p-10 shadow-sm transition-all hover:shadow-xl">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50">
              <Icon className="h-6 w-6 text-blue-600" />
            </div>
            <div class="mb-2 text-4xl font-black text-slate-900">{stat.value}</div>
            <h3 class="mb-4 text-xs font-black tracking-widest text-blue-600 uppercase">
              {stat.title}
            </h3>
            <p class="font-medium text-slate-500">{stat.description}</p>
          </div>
        );
      })}
    </div>
  </section>

  <div class="prose prose-slate max-w-none">
    <h2 class="text-2xl font-black text-slate-900">{localize("AMOLED vs LCD")}</h2>
    <div class="grid gap-8 md:grid-cols-2">
      <div class="rounded-3xl border border-slate-100 p-8">
        <h4 class="mb-4 text-xs font-black tracking-widest text-slate-900 uppercase">
          {localize("AMOLED Logic")}
        </h4>
        <p class="text-sm font-medium text-slate-500">
          {localize("Pixels turn off physically. Black = Zero Power. This is the optimal environment for ScreenVeil.")}
        </p>
      </div>
      <div class="rounded-3xl border border-slate-100 p-8">
        <h4 class="mb-4 text-xs font-black tracking-widest text-slate-400 uppercase">
          {localize("LCD Logic")}
        </h4>
        <p class="text-sm font-medium text-slate-500">
          {localize("Backlight stays on. Black = Dimmed. Efficiency is lower but accidental touch prevention still applies.")}
        </p>
      </div>
    </div>
  </div>
</div>
