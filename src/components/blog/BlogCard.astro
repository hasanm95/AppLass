---
import { cn } from "@/lib/utils";
import type { MarkdownBlogPost } from "@/lib/blog";
import { localePath } from "@/i18n/utils";

interface Props {
  post: MarkdownBlogPost;
  isHero?: boolean;
  lang?: string;
  authorLabel?: string;
}

const { 
  post, 
  isHero = false, 
  lang = "en",
  authorLabel = "Article Author" 
} = Astro.props;

// Determine image source
const imageSrc = post.thumbnail ? (typeof post.thumbnail === 'object' ? post.thumbnail.src : post.thumbnail) : "";
---

<a
  href={localePath(lang, `/blog/${post.slug}`)}
  class={cn(
    "group block h-full rounded-4xl border border-slate-900 transition-all hover:bg-slate-50",
    isHero ? "gap-12 p-1 pt-1 lg:flex" : "p-8"
  )}
>
  {/* Post Thumbnail */}
  <div
    class={cn(
      "relative overflow-hidden rounded-[1.8rem] bg-slate-100 shadow-inner",
      isHero
        ? "aspect-video lg:aspect-auto lg:flex-1"
        : "mb-8 aspect-video"
    )}
  >
    {post.thumbnail ? (
      <img
        src={imageSrc}
        alt={post.title}
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center p-4 text-center text-2xl font-black tracking-widest text-slate-300 uppercase">
        {post.category}
      </div>
    )}

    {/* Subtle hover overlay */}
    <div class="absolute inset-0 bg-blue-600/0 transition-colors duration-500 group-hover:bg-blue-600/5"></div>
  </div>

  <div
    class={cn(
      "flex flex-col",
      isHero ? "p-8 lg:flex-1 lg:py-12 lg:pr-12 lg:pl-0" : ""
    )}
  >
    <div class="mb-6 flex items-center gap-3">
      <span class="text-[10px] font-black tracking-widest text-blue-800 uppercase">
        {post.category}
      </span>
      <span class="h-1 w-1 rounded-full bg-slate-200"></span>
      <span class="text-[10px] font-bold text-slate-500">
        {post.date}
      </span>
    </div>

    <h3
      class={cn(
        "leading-tight font-black tracking-tight text-slate-900 transition-colors group-hover:text-blue-700",
        isHero ? "mb-6 text-4xl md:text-5xl" : "mb-4 text-2xl"
      )}
    >
      {post.title}
    </h3>

    <p
      class={cn(
        "line-clamp-2 leading-relaxed font-medium text-slate-600",
        isHero ? "mb-10 text-xl" : "text-base"
      )}
    >
      {post.excerpt}
    </p>

    {isHero && (
      <div class="mt-auto flex items-center gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-slate-900 text-xs font-bold text-white">
          {"MF"}
        </div>
        <div>
          <p class="text-sm font-black text-slate-900">{post.author}</p>
          <p class="text-xs font-bold text-slate-400">{authorLabel}</p>
        </div>
      </div>
    )}
  </div>
</a>
