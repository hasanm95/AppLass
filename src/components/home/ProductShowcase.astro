---
import Section from "@/components/common/Section.astro";
import { PRODUCTS } from "@/constants/home-data";
import { ExternalLink } from "lucide-react";
import { getDictionary } from "@/i18n/get-dictionary";
import { getLangFromUrl } from "@/i18n/utils";

interface Props {
  productImages?: Record<string, string>;
}

const { productImages = {} } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const dict = await getDictionary(lang as any);
const translations = dict.home?.productShowcase;
const products = dict.products;

// ScreenVeil is the featured product
const featuredDataSource = PRODUCTS[0]; 
const featuredTranslation = products?.screenveil;

const otherDataSources = PRODUCTS.slice(1);
---

<Section
  id="apps"
  className="bg-background py-16 md:py-24 lg:py-32"
>
  <div class="section-container">
    {/* Section Header */}
    <div class="mb-16 flex items-center gap-4 md:mb-20">
      <span class="font-mono text-xs font-bold tracking-widest text-(--muted-foreground)/50 uppercase">
        {translations?.sectionLabel || "PRODUCTS"}
      </span>
      <span class="block h-px flex-1 bg-(--foreground)/20" />
    </div>

    {/* Featured Product: ScreenVeil */}
    <div class="mb-16 md:mb-24">
      <div class="mb-6 flex items-center gap-4">
        <span class="font-mono text-xs font-bold tracking-widest text-(--muted-foreground)/50 uppercase">
          01
        </span>
        <span class="block h-px w-24 bg-cta" />
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">
        {/* Content */}
        <div class="relative border-l-2 border-(--foreground)/10 pl-6 transition-all duration-200 hover:border-l-cta md:pl-8">
          <span class="mb-2 block font-mono text-[10px] font-bold tracking-[0.2em] text-muted-foreground uppercase">
            {featuredTranslation?.platform || featuredDataSource.platform}
          </span>

          <h2 class="font-mono text-4xl font-bold text-foreground md:text-5xl">
            {featuredTranslation?.name || featuredDataSource.name}
          </h2>

          <p class="mb-4 font-mono text-lg font-semibold text-green-600">
            {featuredTranslation?.tagline || featuredDataSource.tagline}
          </p>

          <p class="mb-8 max-w-md text-lg leading-relaxed text-muted-foreground">
            {featuredTranslation?.description || featuredDataSource.description}
          </p>

          <div class="mb-8 flex flex-wrap gap-6">
            <div class="flex items-baseline gap-2">
              <span class="font-mono text-2xl font-bold text-foreground">
                {featuredDataSource.stats?.downloads}
              </span>
              <span class="text-sm text-muted-foreground">
                {translations?.downloadsFeatured || "downloads"}
              </span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="font-mono text-2xl font-bold text-foreground">
                {featuredDataSource.stats?.rating}★
              </span>
              <span class="text-sm text-muted-foreground">
                {translations?.ratingFeatured || "rating"}
              </span>
            </div>
          </div>

          <a
            href={featuredDataSource.ctaLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex cursor-pointer items-center gap-2 bg-green-600 px-6 py-3 font-semibold text-white transition-all duration-200 hover:bg-green-700"
          >
            {featuredTranslation?.cta || featuredDataSource.cta}
            <ExternalLink className="h-4 w-4" />
          </a>
        </div>

        {/* Image */}
        <a
          href={featuredDataSource.ctaLink}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${featuredTranslation?.name || featuredDataSource.name}`}
          class="relative flex items-center justify-center transition-transform hover:scale-[1.02]"
        >
          <div class="relative w-full overflow-hidden rounded-2xl border border-border bg-linear-to-br from-green-50 to-green-100 p-12">
            <img
              src={productImages[featuredDataSource.id] || (featuredDataSource as any).imageSrc}
              alt={featuredTranslation?.name || featuredDataSource.name}
              width={600}
              height={600}
              class="object-contain"
            />
          </div>
          {/* Decorative corner */}
          <div role="presentation" class="absolute -right-4 -bottom-4 h-16 w-16 rounded-lg border-2 border-green-600/30" />
        </a>
      </div>
    </div>

    {/* Other Products - Asymmetric Grid */}
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-12">
      {otherDataSources.map((product, idx) => {
        const isFomoGen = product.id === "fomogen";
        const accentColor = isFomoGen
          ? "text-cta"
          : "text-primary";
          
        // Map the product ID to the correct key in the translation dictionary
        const dictKey = product.id === "mindful" ? "mindfulGuard" : product.id;
        const translation = products?.[dictKey as keyof typeof products];

        return (
          <a
            href={product.ctaLink}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`View ${translation?.name || product.name}`}
            class="group relative cursor-pointer border-l-2 border-(--foreground)/10 pl-6 transition-all duration-200 hover:border-l-cta md:pl-8"
          >
            {/* Number */}
            <div class="mb-6 flex items-center gap-4">
              <span class="font-mono text-xs font-bold tracking-widest text-(--muted-foreground)/50 uppercase">
                0{idx + 2}
              </span>
              <span role="presentation" class="block h-px w-16 bg-(--foreground)/20 transition-colors group-hover:bg-cta" />
            </div>

            {/* Image */}
            <div class="mb-6 overflow-hidden rounded-xl border border-border bg-(--muted)/30 p-6">
              <img
                src={productImages[product.id] || (product as any).imageSrc}
                alt={translation?.name || product.name}
                width={600}
                height={600}
                class="object-contain transition-transform duration-300 group-hover:scale-105"
              />
            </div>

            {/* Content */}
            <span class="mb-2 block font-mono text-[10px] font-bold tracking-[0.2em] text-muted-foreground uppercase">
              {translation?.platform || product.platform}
            </span>

            <h3 class="font-mono text-xl font-bold text-foreground md:text-2xl">
              {translation?.name || product.name}
            </h3>

            <p
              class={`mb-4 font-mono text-sm font-semibold ${accentColor}`}
            >
              {translation?.tagline || product.tagline}
            </p>

            <p class="mb-6 text-sm leading-relaxed text-muted-foreground">
              {translation?.description || product.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {(translation?.metrics || product.metrics).map((metric: string) => (
                <span
                  class="border border-border px-3 py-1 font-mono text-xs font-semibold text-foreground"
                >
                  {metric}
                </span>
              ))}
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Section>
