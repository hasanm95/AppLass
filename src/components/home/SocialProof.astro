---
import Section from "@/components/common/Section.astro";
import { getDictionary } from "@/i18n/get-dictionary";
import { getLangFromUrl } from "@/i18n/utils";

const METRICS = [
  { id: "downloads", value: "10K+", label: "Downloads" },
  { id: "playStore", value: "4.4★", label: "Play Store" },
  { id: "payload", value: "<2.1KB", label: "Payload" },
  { id: "telemetry", value: "Zero", label: "Telemetry" },
];

const lang = getLangFromUrl(Astro.url);
const dict = await getDictionary(lang as any);
const translations = dict.home?.socialProof;

type MetricKey = "downloads" | "playStore" | "payload" | "telemetry";
---

<Section className="border-y border-border bg-(--muted)/50 py-12 md:py-16">
  <div class="section-container">
    {/* Horizontal metrics strip */}
    <div class="flex flex-wrap items-center justify-between gap-8 md:gap-12">
      {/* Intro text */}
      <div class="flex items-center gap-4">
        <span class="block h-px w-16 bg-foreground/20" />
        <span class="text-sm font-medium text-muted-foreground">
          {translations?.trustedBy ? (
            <>
              {translations.trustedBy.split("{count}")[0]}
              <span class="font-bold text-foreground">10,000+</span>
              {translations.trustedBy.split("{count}")[1]}
            </>
          ) : (
            <>
              Trusted by{" "}
              <span class="font-bold text-foreground">
                10,000+
              </span>{" "}
              users
            </>
          )}
        </span>
      </div>

      {/* Metrics */}
      <div class="flex flex-wrap items-center gap-8 md:gap-12">
        {METRICS.map((metric) => (
            <div class="flex flex-col">
              <span class="font-mono text-2xl font-bold text-foreground md:text-3xl">
                {translations?.metrics?.[metric.id as MetricKey]?.value || metric.value}
              </span>
              <span class="text-xs font-medium tracking-wide text-muted-foreground uppercase">
                {translations?.metrics?.[metric.id as MetricKey]?.label || metric.label}
              </span>
              <span class="mt-2 block h-px w-16 bg-foreground/20" />
            </div>
        ))}
      </div>

      {/* Google Play Badge */}
      <a
        href="https://play.google.com/store/apps/details?id=com.screenveil.app"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex cursor-pointer items-center gap-3 border-2 border-border bg-card px-5 py-3 transition-all duration-200 hover:border-foreground"
      >
        <svg
          class="h-6 w-6 text-foreground"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z" />
        </svg>
        <div class="text-left">
          <span class="block text-[9px] font-bold tracking-wider text-muted-foreground uppercase">
            {translations?.googlePlay?.getItOn || "Get it on"}
          </span>
          <span class="block text-sm font-bold text-foreground">
            {translations?.googlePlay?.storeName || "Google Play"}
          </span>
        </div>
      </a>
    </div>
  </div>
</Section>
