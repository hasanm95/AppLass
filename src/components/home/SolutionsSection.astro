---
import Section from "@/components/common/Section.astro";
import { getSolutions } from "@/constants/home-data";
import { ShoppingBag, Clock, Users } from "lucide-react";
import { localize } from "@/i18n/localize";
import Localize from "@/components/i18n/Localize";
import React from 'react';

const ICONS = {
  ShoppingBag,
  Clock,
  Users,
};

const solutionsData = getSolutions();

const s_components = [
  React.createElement('span', { className: 'border-b-2 border-cta/40 font-semibold text-foreground' })
];
---

<Section
  id="solutions"
  className="bg-card py-16 md:py-24 lg:py-32"
>
  <div class="section-container">
    {/* Section Header */}
    <div class="mb-16 md:mb-24">
      <div class="mb-8 flex items-center gap-4">
        <span class="font-mono text-xs font-bold tracking-widest text-muted-foreground/50 uppercase">
        {localize("SOLUTIONS")}
      </span>
      <span class="block h-px flex-1 bg-foreground/20" />
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <h2 class="font-mono text-2xl leading-tight font-bold text-foreground md:text-3xl lg:text-4xl">
          {localize("Logical")}
          <br />
          <span class="text-muted-foreground/40">
            {localize("Solutions.")}
          </span>
        </h2>

        <div class="flex items-end">
          <p class="max-w-md text-lg leading-relaxed text-muted-foreground">
            <Localize 
              i18n_default_text="We don't just build features; we engineer <0>systemic improvements</0> that solve core business logic bottlenecks."
              components={s_components}
            />
          </p>
        </div>
      </div>
    </div>

    {/* Solutions Grid */}
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {solutionsData.map((solution, index) => {
        const Icon = ICONS[solution.iconName as keyof typeof ICONS];

        return (
          <div
            class="group cursor-pointer border border-border bg-background p-6 transition-all duration-200 hover:border-cta md:p-8"
          >
            {/* Number */}
            <div class="mb-6 flex items-center justify-between">
              <span class="font-mono text-xs font-bold tracking-widest text-muted-foreground/50 uppercase">
                0{index + 1}
              </span>
              <div class="flex h-10 w-10 items-center justify-center border border-border transition-all duration-200 group-hover:border-cta group-hover:bg-cta/5">
                {Icon && (
                  <Icon className="h-5 w-5 text-muted-foreground transition-colors group-hover:text-cta" />
                )}
              </div>
            </div>

            <span class="mb-6 block h-px w-16 bg-foreground/20" />

            <h3 class="mb-3 font-mono text-lg font-bold text-foreground md:text-xl">
              {solution.title}
            </h3>
            <p class="text-sm leading-relaxed text-muted-foreground">
              {solution.description}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</Section>
