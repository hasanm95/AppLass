---
import Section from "@/components/common/Section.astro";
import { getHomePillars } from "@/constants/home-data";
import { getDictionary } from "@/i18n/get-dictionary";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { Zap, Calculator, Globe } from "lucide-react";

const ICONS = {
  Zap,
  Calculator,
  Globe,
};

const lang = getLangFromUrl(Astro.url);
const dict = await getDictionary(lang as any);
const translations = dict.home?.foundersMoat;
const pillars = dict.pillars;

// Create a translation function scoped to the pillars dictionary
const t = useTranslations({ pillars });
const pillarsData = getHomePillars(t);
---

<Section
  id="about"
  className="relative bg-muted py-16 md:py-24 lg:py-32"
>
  <div class="section-container">
    {/* Section Header */}
    <div class="mb-16 md:mb-24">
      <div class="mb-8 flex items-center gap-4">
        <span class="font-mono text-xs font-bold tracking-widest text-(--muted-foreground)/50 uppercase">
          {translations?.sectionLabel || "PHILOSOPHY"}
        </span>
        <span class="block h-px flex-1 bg-(--foreground)/20" />
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <h2 class="font-mono text-2xl leading-tight font-bold text-foreground md:text-3xl lg:text-4xl">
          {translations?.headline || "Built Different"}
          <br />
          <span class="text-(--muted-foreground)/40">
            {translations?.headlineAccent || "by Logic."}
          </span>
        </h2>

        <div class="flex items-end">
          <p class="max-w-md border-l-2 border-(--cta)/30 pl-6 text-lg leading-relaxed text-muted-foreground italic">
            {translations?.quote || '"AppLass apps are developed using mathematical optimization techniques to minimize JavaScript execution time."'}
          </p>
        </div>
      </div>
    </div>

    {/* Pillars - Vertical Timeline Style */}
    <div class="relative">
      {/* Connecting Line */}
      <div class="absolute top-0 bottom-0 left-4 hidden w-px bg-border md:block" />

      <div class="space-y-8 md:space-y-12">
        {pillarsData.map((pillar, index) => {
          const Icon = ICONS[pillar.iconName as keyof typeof ICONS];

          return (
            <div class="group relative grid grid-cols-1 gap-6 md:grid-cols-[80px_1fr] md:gap-12">
              {/* Number & Icon */}
              <div class="flex items-start gap-4 md:flex-col md:items-center">
                <span class="font-mono text-xs font-bold tracking-widest text-(--muted-foreground)/50 uppercase">
                  0{index + 1}
                </span>
                <div class="flex h-10 w-10 items-center justify-center border border-border bg-card transition-all duration-200 group-hover:border-cta group-hover:bg-(--cta)/5">
                  {Icon && (
                    <Icon className="h-5 w-5 text-muted-foreground transition-colors group-hover:text-cta" />
                  )}
                </div>
              </div>

              {/* Content */}
              <div class="relative border-l-2 border-(--foreground)/10 bg-card py-6 pl-6 transition-all duration-200 hover:border-l-cta md:pl-8">
                <span class="mb-2 block font-mono text-[10px] font-bold tracking-[0.2em] text-muted-foreground uppercase">
                  {pillar.label}
                </span>
                <h3 class="mb-3 font-mono text-lg font-bold text-foreground md:text-xl">
                  {pillar.title}
                </h3>
                <p class="max-w-lg text-muted-foreground">
                  {pillar.description}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</Section>
