---
import { localize } from "@/i18n/localize";
import { getLangFromUrl, localePath } from "@/i18n/utils";
import { ArrowRight } from "lucide-react";

const lang = getLangFromUrl(Astro.url);
---

<section
  class="relative flex h-screen items-center overflow-hidden bg-background pt-20"
  aria-label="Introduction"
>
  {/* Subtle grid background */}
  <div
    class="pointer-events-none absolute inset-0 opacity-30"
    style={{
      backgroundImage:
        "linear-gradient(#E2E8F0 1px, transparent 1px), linear-gradient(90deg, #E2E8F0 1px, transparent 1px)",
      backgroundSize: "80px 80px",
    }}
  />

  {/* Gradient fade */}
  <div class="pointer-events-none absolute inset-0 bg-linear-to-b from-background via-transparent to-background" />

  <div class="section-container relative z-10 py-12 md:py-16">
    <div class="max-w-5xl">
      {/* Eyebrow */}
      <div class="mb-8 flex items-center gap-4">
        <span class="block h-px w-24 bg-cta" />
        <span class="font-mono text-[10px] font-bold tracking-[0.2em] text-cta uppercase">
          {localize("Elite Software Studio")}
        </span>
      </div>

      {/* Massive Headline - Left Aligned */}
      <h1 class="mb-4 font-mono text-4xl leading-[1.1] font-bold tracking-tight md:text-6xl lg:text-7xl">
        <span class="block">{localize("High-Performance")}</span>
        <span class="block text-primary">{localize("Apps.")}</span>
        <span class="block text-muted-foreground/30">
          {localize("Zero Bloat.")}
        </span>
      </h1>

      {/* Subheading */}
      <p class="mb-8 max-w-2xl text-base leading-relaxed text-muted-foreground md:text-lg">
        {localize("Stop letting bloated Shopify apps kill your conversions. {brand} builds elite-tier tools with {payload} payloads that keep your Core Web Vitals green.", {
          brand: <span class="font-semibold text-foreground">AppLass</span>,
          payload: (
            <span class="inline-flex items-center gap-1 border-b-2 border-(--cta)/40 font-mono text-foreground">
              &lt;2.1KB
            </span>
          )
        })}
      </p>

      {/* Stats Row */}
      <div class="mb-8 flex flex-wrap items-baseline gap-8 text-sm">
        <div>
          <span class="font-mono text-2xl font-bold text-foreground md:text-3xl">
            {localize("10K+")}
          </span>
          <span class="ml-2 text-muted-foreground">
            {localize("Downloads")}
          </span>
        </div>
        <div class="h-6 w-px bg-border" />
        <div>
          <span class="font-mono text-2xl font-bold text-foreground md:text-3xl">
            {localize("4.4★")}
          </span>
          <span class="ml-2 text-muted-foreground">
            {localize("Rating")}
          </span>
        </div>
        <div class="h-6 w-px bg-border" />
        <div>
          <span class="font-mono text-2xl font-bold text-foreground md:text-3xl">
            {localize("<2.1KB")}
          </span>
          <span class="ml-2 text-muted-foreground">
            {localize("Payload")}
          </span>
        </div>
      </div>

      {/* CTAs */}
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
        <a
          href={localePath(lang, '/apps')}
          class="group inline-flex cursor-pointer items-center justify-center gap-2 border-2 border-foreground bg-foreground px-8 py-4 font-semibold text-background transition-all duration-200 hover:bg-transparent hover:text-foreground"
        >
          {localize("See Our Apps")}
          <ArrowRight className="h-5 w-5 transition-transform group-hover:translate-x-1" />
        </a>
        <a
          href={localePath(lang, '/blog')}
          class="group inline-flex cursor-pointer items-center justify-center gap-2 border-2 border-(--foreground)/20 bg-transparent px-8 py-4 font-semibold text-foreground transition-all duration-200 hover:border-foreground"
        >
          {localize("Read the Logic Lab")}
          <ArrowRight className="h-5 w-5 transition-transform group-hover:translate-x-1" />
        </a>
      </div>
    </div>
  </div>

  {/* Decorative vertical line */}
  <div class="pointer-events-none absolute top-1/4 right-12 hidden h-48 w-px bg-linear-to-b from-transparent via-(--cta)/30 to-transparent lg:block" />
</section>
