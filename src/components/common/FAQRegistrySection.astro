---
import Section from "@/components/common/Section.astro";
import FAQSchema from "@/components/common/FAQSchema.astro";
import { getFaqRegistry, type FAQRegistryKey } from "@/constants/faq-registry";
import { Plus, Minus } from "lucide-react";
import { localize } from "@/i18n/localize";
import { cn } from "@/lib/utils";

interface Props {
  registryKey?: FAQRegistryKey;
  items?: { question: string; answer: string }[];
  className?: string;
  title?: string;
  subtitle?: string;
  variant?: "fragmented" | "centered" | "grid";
}

const {
  registryKey,
  items: propItems,
  className,
  title,
  subtitle,
  variant = "grid",
} = Astro.props;

const items = propItems || (registryKey ? getFaqRegistry()[registryKey] : []);

const tTitle = title || localize("Frequently Asked Questions");
const tSubtitle = subtitle || localize("Technical Clarifications");
---

<Section
  id="faq"
  className={cn("border-t border-slate-200 bg-[#FBFBFA]", className)}
>
  <div class="section-container">
    <div class={cn("mb-24", variant === "centered" && "text-center")}>
      <span class="mb-6 block font-mono text-[10px] font-bold tracking-[0.3em] text-blue-600 uppercase">
        {tSubtitle}
      </span>
      <h2 class="text-5xl font-black tracking-tighter text-slate-950 md:text-6xl">
        {tTitle.split(" ").slice(0, -1).join(" ")}
        <br />
        <span class="text-slate-300">{tTitle.split(" ").slice(-1)}</span>
      </h2>
    </div>

    <div
      class={cn(
        "grid grid-cols-1 gap-4",
        variant === "grid" && "lg:grid-cols-2 lg:gap-8",
        variant === "centered" && "mx-auto max-w-4xl"
      )}
    >
      {items.map((faq, idx) => (
        <article
          class="faq-reg-item group relative border-2 border-slate-950 bg-white transition-all hover:bg-slate-50"
        >
          {/* Technical Marker */}
          <div class="absolute top-4 right-12 font-mono text-[8px] text-slate-300 uppercase">
            [ Protocol.Entry_0{idx + 1} ]
          </div>

          <button
            class="faq-reg-trigger flex w-full items-start justify-between p-10 text-left"
            aria-expanded="false"
          >
            <h3 class="text-xl leading-tight font-black tracking-tight text-slate-950">
              {faq.question}
            </h3>
            <div class="mt-1 ml-4 flex h-6 w-6 shrink-0 items-center justify-center rounded border border-slate-200 bg-slate-50 transition-colors group-hover:border-blue-500/30">
              <Plus className="plus-icon h-3 w-3 text-slate-400" />
              <Minus className="minus-icon h-3 w-3 text-blue-600 hidden" />
            </div>
          </button>

          <div class="faq-reg-content grid transition-all duration-300 grid-rows-[0fr] opacity-0 overflow-hidden">
            <div class="min-h-0 px-10 pb-10">
              <p class="leading-relaxed font-medium text-slate-600">
                {faq.answer}
              </p>
              
              <div class="mt-8 flex items-center gap-4">
                <div class="h-px flex-1 bg-slate-100" />
                <div class="h-2 w-2 bg-blue-600" />
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <FAQSchema items={items} />
</Section>

<script>
  function initFAQReg() {
    const items = document.querySelectorAll('.faq-reg-item');
    
    items.forEach(item => {
      const trigger = item.querySelector('.faq-reg-trigger');
      const content = item.querySelector('.faq-reg-content') as HTMLElement;
      const plusIcon = item.querySelector('.plus-icon');
      const minusIcon = item.querySelector('.minus-icon');

      trigger?.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        
        // Toggle current
        if (isExpanded) {
          trigger.setAttribute('aria-expanded', 'false');
          if (content) content.style.maxHeight = '0';
          content?.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
          content?.classList.replace('opacity-100', 'opacity-0');
          plusIcon?.classList.remove('hidden');
          minusIcon?.classList.add('hidden');
          item.classList.remove('bg-slate-50');
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          if (content) content.style.maxHeight = content.scrollHeight + 'px';
          content?.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
          content?.classList.replace('opacity-0', 'opacity-100');
          plusIcon?.classList.add('hidden');
          minusIcon?.classList.remove('hidden');
          item.classList.add('bg-slate-50');
        }
      });
    });
  }

  // Init on load and after swap
  initFAQReg();
  document.addEventListener('astro:after-swap', initFAQReg);
</script>
