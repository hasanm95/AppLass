---
import Section from "@/components/common/Section.astro";
import { getFaqRegistry, type FAQRegistryKey } from "@/constants/faq-registry";
import { FAQSchema } from "@/components/common/FAQSchema";
import { localize } from "@/i18n/localize";
import clsx from "clsx";

interface Props {
  registryKey?: FAQRegistryKey;
  items?: { question: string; answer: string }[];
  className?: string;
  title?: string;
  subtitle?: string;
  variant?: "fragmented" | "centered" | "grid";
}

const {
  registryKey,
  items: propItems,
  className,
  title,
  subtitle,
  variant = "grid",
} = Astro.props;

// For backwards compatibility with pages that still supply props, propItems wins,
// otherwise get from dictionary via provided global registry key
const items = propItems || (registryKey ? getFaqRegistry()[registryKey] : []);

const tTitle = title || localize("Frequently Asked Questions");
const tSubtitle = subtitle || localize("Technical Clarifications");

---

<Section
  id="faq"
  className={clsx("border-t border-slate-200 bg-[#FBFBFA]", className)}
>
  <div class="section-container">
    <div class={clsx("mb-24", variant === "centered" && "text-center")}>
      <span class="mb-6 block font-mono text-[10px] font-bold tracking-[0.3em] text-blue-600 uppercase">
        {tSubtitle}
      </span>
      <h2 class="text-5xl font-black tracking-tighter text-slate-950 md:text-6xl">
        {tTitle.split(" ").slice(0, -1).join(" ")}
        <br />
        <span class="text-slate-300">{tTitle.split(" ").slice(-1)}</span>
      </h2>
    </div>

    <div
      class={clsx(
        "grid grid-cols-1 gap-8",
        variant === "grid" && "lg:grid-cols-2",
        variant === "centered" && "mx-auto max-w-4xl"
      )}
    >
      {items.map((faq, idx) => (
        <div
          class={clsx(
            "group relative border-2 border-slate-950 bg-white p-10 transition-all hover:bg-slate-50",
            variant === "fragmented" && idx % 2 === 1 && "lg:mt-16"
          )}
        >
          <div class="absolute top-4 right-4 font-mono text-[8px] text-slate-300 uppercase">
            [ Protocol.Entry_0{idx + 1} ]
          </div>

          <h3 class="mb-6 text-xl leading-tight font-black tracking-tight text-slate-950">
            {faq.question}
          </h3>
          <p class="leading-relaxed font-medium text-slate-600">
            {faq.answer}
          </p>

          <div class="mt-8 flex items-center gap-4">
            <div class="h-px flex-1 bg-slate-100" />
            <div class="h-2 w-2 bg-blue-600" />
          </div>
        </div>
      ))}
    </div>
  </div>

  <FAQSchema items={items} />
</Section>
