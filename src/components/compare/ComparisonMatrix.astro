---
import Section from "@/components/common/Section.astro";
import { Check } from "lucide-react";
import type { ComparisonFeature } from "@/lib/compare";
import { localize } from "@/i18n/localize";

interface Props {
  competitorName: string;
  productName: string;
  features: ComparisonFeature[];
}

const { competitorName, productName, features } = Astro.props;
---
<Section className="bg-white py-24">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <h2 class="text-4xl font-black tracking-tight text-slate-900">
        {localize("Logical Superiority")}
      </h2>
      <p class="mt-4 font-medium text-slate-500">
        {localize("Quantifiable metrics don't lie. See the difference in architecture.")}
      </p>
    </div>

    {/* Desktop Table */}
    <div class="hidden overflow-hidden rounded-4xl border border-slate-200 bg-white shadow-xl md:block">
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="border-b border-slate-100 bg-slate-50/50">
            <th scope="col" class="p-8 text-xs font-black tracking-widest text-slate-500 uppercase">
              {localize("Feature")}
            </th>
            <th scope="col" class="p-8 text-xs font-black tracking-widest text-slate-500 uppercase">
              {competitorName}
            </th>
            <th scope="col" class="bg-blue-50/5 p-8 text-xs font-black tracking-widest text-blue-800 uppercase">
              {productName}
            </th>
          </tr>
        </thead>
        <tbody>
          {features.map((feature) => (
            <tr class="border-b border-slate-50 transition-colors last:border-0 hover:bg-slate-50/50">
              <th scope="row" class="p-8 text-sm font-bold text-slate-600">
                {feature.label}
              </th>
              <td class="p-8 text-sm font-medium text-slate-500">
                {feature.competitorValue}
              </td>
              <td class="bg-blue-500/2 p-8 text-sm font-black text-slate-900">
                <div class="flex items-center gap-3">
                  <Check className="h-4 w-4 text-blue-600" aria-hidden="true" />
                  {feature.applassValue}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {/* Mobile View */}
    <div class="grid grid-cols-1 gap-6 md:hidden">
      {features.map((feature) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <p class="mb-4 text-[10px] font-black tracking-widest text-slate-500 uppercase">
            {feature.label}
          </p>
          <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between opacity-70">
              <span class="text-xs font-bold text-slate-500">{competitorName}</span>
              <span class="text-xs font-medium text-slate-500">{feature.competitorValue}</span>
            </div>
            <div class="flex items-center justify-between border-t border-slate-100 pt-4">
              <span class="text-xs font-black text-blue-800">{productName}</span>
              <span class="text-sm font-black text-slate-900">{feature.applassValue}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Section>
