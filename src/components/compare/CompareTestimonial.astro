---
import Section from "@/components/common/Section.astro";
import { Quote } from "lucide-react";
import { localize } from "@/i18n/localize";

interface Props {
  quote: string;
  author: string;
  role: string;
}

const { quote, author, role } = Astro.props;
---
<Section className="bg-white py-24">
  <div class="section-container">
    <div class="relative mx-auto max-w-4xl rounded-[3rem] border border-blue-100 bg-blue-50 p-12 text-center md:p-20">
      <Quote className="absolute top-12 left-1/2 h-12 w-12 -translate-x-1/2 text-blue-200" aria-hidden="true" />
      <p class="relative z-10 mb-12 text-2xl leading-tight font-black text-slate-900 italic md:text-3xl">
        &quot;{quote}&quot;
      </p>
      <div class="flex flex-col items-center">
        <div class="mb-6 h-0.5 w-12 bg-blue-600" />
        <p class="text-lg font-black text-slate-900">{author}</p>
        <p class="text-sm font-bold tracking-widest text-slate-400 uppercase">
          {role}
        </p>
      </div>
    </div>
  </div>
</Section>
