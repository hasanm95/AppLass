---
import Section from "@/components/common/Section.astro";
import { TrendingUp, UserRoundCheck, ShieldCheck } from "lucide-react";
import { localize } from "@/i18n/localize";

const cards = [
  {
    icon: TrendingUp,
    title: localize("SEO Impact"),
    desc: localize("Faster load times and clean semantic HTML lead to better Google rankings and higher organic visibility."),
  },
  {
    icon: UserRoundCheck,
    title: localize("Conversion Impact"),
    desc: localize("Higher accessibility (WCAG 2.1) means your logic doesn't exclude 20% of the world's population."),
  },
  {
    icon: ShieldCheck,
    title: localize("Integrity First"),
    desc: localize("Your data stays yours. Zero-telemetry architecture means we never log personal identifiers."),
  },
];
---
<Section className="bg-white py-24">
  <div class="section-container">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {cards.map((card) => {
        const Icon = card.icon;
        return (
          <div class="group rounded-3xl border border-slate-200 bg-white p-10 transition-all hover:border-blue-600/30">
            <div class="mb-8 w-fit rounded-2xl bg-blue-600/10 p-4 transition-colors group-hover:bg-blue-600/20">
              <Icon className="h-8 w-8 text-blue-600" aria-hidden="true" />
            </div>
            <h4 class="mb-4 text-xl font-black text-slate-900">
              {card.title}
            </h4>
            <p class="leading-relaxed font-medium text-slate-600">
              {card.desc}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</Section>
