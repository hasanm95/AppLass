---
import Section from "@/components/common/Section.astro";
import { LinkButton } from "../ui/link-button";
import { localize } from "@/i18n/localize";

interface Props {
  headline: string;
  subheadline: string;
}

const { headline, subheadline } = Astro.props;
---
<Section className="bg-iridescent border-b border-slate-100 pt-32 pb-20">
  <div class="relative z-10 flex flex-col items-center text-center">
    <span class="mb-6 block text-[10px] font-black tracking-[0.2em] text-blue-800 uppercase">
      {localize("Analytical Choice")}
    </span>
    <slot name="meta" />
    <h1 class="text-display mb-8 max-w-5xl text-slate-900">
      {headline}
    </h1>
    <p class="mx-auto mb-12 max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
      {subheadline}
    </p>
    <LinkButton href="https://apps.shopify.com/fomogen" target="_blank" rel="noopener noreferrer" className="h-14 rounded-xl bg-slate-900 px-8 text-lg font-bold text-white hover:bg-slate-800">
      {localize("Make the Switch — Get Started Free")}
    </LinkButton>
    <slot name="ai-summary" />
  </div>
</Section>
