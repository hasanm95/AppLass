---
import LegalPage from "@/page-templates/LegalPage.astro";
import Content from "@/components/legal/ScreenveilPrivacy.astro";
import { Smartphone } from "lucide-react";
import { localize } from "@/i18n/localize";

const lang = "en";
const description = localize("Privacy Policy for ScreenVeil - Our transparent approach to Android AMOLED efficiency and zero data collection.");
---

<LegalPage 
  lang={lang}
  title="Privacy Policy"
  appName="ScreenVeil"
  description={description}
>
  <div slot="branding" class="flex items-center gap-2">
    <Smartphone className="h-5 w-5 text-blue-600 fill-blue-600" />
    <span class="text-lg font-black tracking-tighter text-slate-900 uppercase">
      Screen<span class="text-blue-600">Veil</span>
    </span>
  </div>
  <Content lastUpdated="August 2025" />
</LegalPage>
