---
import LegalPage from "@/page-templates/LegalPage.astro";
import Content from "@/components/legal/MindfulGuardTerms.astro";
import { Shield } from "lucide-react";
import { localize } from "@/i18n/localize";

const lang = "en";
const description = localize("Terms of Service for Mindful Guard - Understanding the user agreement and focus session rules for our Android app.");
---

<LegalPage 
  lang={lang}
  title="Terms of Service"
  appName="Mindful Guard"
  description={description}
>
  <div slot="branding" class="flex items-center gap-2">
    <Shield className="h-5 w-5 text-slate-900 fill-slate-900" />
    <span class="text-lg font-black tracking-tighter text-slate-900 uppercase">
      Mindful<span class="text-slate-400">Guard</span>
    </span>
  </div>
  <Content />
</LegalPage>
