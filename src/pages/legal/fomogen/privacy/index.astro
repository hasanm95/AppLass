---
import LegalPage from "@/page-templates/LegalPage.astro";
import Content from "@/components/legal/FomogenPrivacy.astro";
import { Zap } from "lucide-react";
import { localize } from "@/i18n/localize";

const lang = "en";
const description = localize("Privacy Policy for FOMOGEN - Learn how we collect, use, and protect your information as a Shopify merchant.");
---

<LegalPage 
  lang={lang}
  title="Privacy Policy"
  appName="FOMOGEN"
  description={description}
>
  <div slot="branding" class="flex items-center gap-2">
    <Zap className="h-5 w-5 text-blue-600 fill-blue-600" />
    <span class="text-lg font-black tracking-tighter text-slate-900">
      FOMO<span class="text-blue-600">GEN</span>
    </span>
  </div>
  <Content />
</LegalPage>
