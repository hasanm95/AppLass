---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import Section from "@/components/common/Section.astro";
import { comparisons } from "@/lib/compare";
import { ArrowRight } from "lucide-react";
import { localize } from "@/i18n/localize";
import { i18nConfig } from "@/i18n/config";
import { localePath } from "@/i18n/utils";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;

import { setLocale } from "@/i18n";
setLocale(lang);

const meta = {
  title: localize("Comparison Guides | AppLass Analysis"),
  description: localize("Logic-first product comparisons. Why elite teams choose AppLass over legacy alternatives."),
  keywords: localize("applass vs, software comparison, technical analysis, shopify app alternatives"),
  ogTitle: localize("Comparison Guides | AppLass Analysis"),
  ogDescription: localize("Logic-first product comparisons and technical analysis."),
  ogImage: "https://applass.com/og-image.jpg",
  ogUrl: `https://applass.com/${lang}/compare`
};

---

<Layout 
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <div class="min-h-screen bg-white">
    <Navbar    />
    <div class="pt-32">
      <Section className="bg-iridescent border-b border-slate-100 py-20 lg:py-32">
        <div class="section-container">
          <span class="mb-6 block text-[10px] font-black tracking-[0.2em] text-blue-800 uppercase">
            {localize("Analytical Logic")}
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-display mb-8 max-w-4xl text-slate-900">
            {localize("Technical ")}
            <span class="text-slate-300">{localize("Analysis.")}</span>
          </h1>
          <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-500">
            {localize("Why elite teams are switching to our ecosystem. A cold, logic-first derivation of technical superiority.")}
          </p>
        </div>
      </Section>

      <Section className="py-24">
        <div class="section-container grid grid-cols-1 gap-8 md:grid-cols-2">
          {comparisons.map((c) => (
            <a
              href={localePath(lang, `/compare/${c.slug}`)}
              class="group flex items-center justify-between rounded-[2.5rem] border border-slate-100 bg-[#FAFBFD] p-10 transition-all hover:border-blue-500/20 hover:bg-white hover:shadow-xl"
            >
              <div>
                <span class="mb-2 block text-[10px] font-black tracking-widest text-slate-400 uppercase">
                  {localize("Product Comparison")}
                </span>
                <h2 class="text-3xl font-black text-slate-900">
                  {c.productName} <span class="text-slate-300">{localize("vs")}</span>{" "}
                  {c.competitorName}
                </h2>
              </div>
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-900 transition-all group-hover:bg-blue-600 group-hover:text-white">
                <ArrowRight size={20} />
              </div>
            </a>
          ))}
        </div>

        <div class="mt-24 rounded-[3rem] border border-slate-900 bg-slate-900 p-12 text-center text-white md:p-20">
          <h3 class="mb-8 text-4xl font-black md:text-5xl">
            {localize("Experience Logical Superiority.")}
          </h3>
          <p class="mx-auto mb-12 max-w-2xl text-xl font-medium text-slate-400">
            {localize("Stop settling for technical debt. Switch to a foundation built on first principles.")}
          </p>
          <a
            href={localePath(lang, "/apps")}
            class="inline-flex h-16 items-center justify-center rounded-2xl bg-blue-600 px-12 text-lg font-bold text-white transition-all hover:scale-105 hover:bg-blue-500"
          >
            {localize("Explore Ecosystem")}
          </a>
        </div>
      </Section>
    </div>
    <Footer />
  </div>
</Layout>
