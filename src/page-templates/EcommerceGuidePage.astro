---
import Layout from '../layouts/Layout.astro';
import { FAQSchema } from "@/components/common/FAQSchema";
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import Section from "@/components/common/Section.astro";
import {
  Gauge,
  Sparkles,
  TrendingUp,
  CheckCircle2,
  Zap,
  BarChart3,
  MousePointer2,
} from "lucide-react";
import { getDictionary } from "@/i18n/get-dictionary";
import { i18nConfig } from "@/i18n/config";
import { localePath, useTranslations } from "@/i18n/utils";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;
const dict = await getDictionary(lang as any);
const t = useTranslations(lang);

const meta = dict.metadata?.ecommercePerformance || {};
const faqItems = dict.faqRegistry?.ECOMMERCE_PERFORMANCE || [];

---

<Layout 
  title={meta.title || "Ecommerce Performance Guide 2026: Benchmarks & Conversion Hacks"}
  description={meta.description || "Master ecommerce performance in 2026. Discover the latest Shopify speed benchmarks, social proof strategies that boost sales by 98%, and CRO tools like sticky carts."}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <div class="min-h-screen bg-white font-sans selection:bg-blue-100 selection:text-blue-900">
    <Navbar    />

    <main class="pt-32">
      {/* Hero Section */}
      <Section className="bg-iridescent border-b border-slate-100 py-12 lg:py-32">
        <div class="section-container">
          <span class="mb-4 lg:mb-6 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
            {t("ecommerceGuide.hero.eyebrow")}
          </span>
          <div class="mb-4 lg:mb-6 flex items-center gap-2">
            <CheckCircle2 className="h-4 w-4 text-emerald-600" />
            <span class="text-xs font-bold text-slate-500 italic">
              {t("ecommerceGuide.hero.verification")}
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-display mb-6 lg:mb-8 max-w-5xl text-slate-900">
            {t("ecommerceGuide.hero.headline")}
            <span class="text-slate-300">
              {t("ecommerceGuide.hero.headlineAccent")}
            </span>
          </h1>
          <p class="max-w-3xl text-xl leading-relaxed font-medium text-slate-600">
            {t("ecommerceGuide.hero.description")}
          </p>
        </div>
      </Section>

      {/* Technical Speed Benchmarks */}
      <Section className="py-12 lg:py-24">
        <div class="section-container">
          <div class="mb-12 lg:mb-20">
            <h2 class="mb-4 lg:mb-6 text-3xl lg:text-4xl font-black text-slate-900">
              {t("ecommerceGuide.technicalSpeed.title")}
            </h2>
            <p class="max-w-2xl text-lg leading-relaxed font-medium text-slate-500">
              {t("ecommerceGuide.technicalSpeed.description")}
            </p>
          </div>

          <div class="mb-10 lg:mb-16 grid grid-cols-1 gap-6 lg:gap-8 md:grid-cols-3">
            <div class="rounded-3xl lg:rounded-[2.5rem] border border-slate-100 bg-slate-50 p-6 lg:p-10">
              <div class="mb-4 lg:mb-6 flex items-center gap-3 lg:gap-4">
                <div class="rounded-xl bg-blue-100 p-2 lg:p-3 text-blue-600">
                  <Gauge size={24} />
                </div>
                <h4 class="font-black text-slate-900">{t("ecommerceGuide.technicalSpeed.lcp.title")}</h4>
              </div>
              <span class="mb-2 block text-2xl lg:text-3xl font-black text-slate-900">
                {t("ecommerceGuide.technicalSpeed.lcp.value")}
              </span>
              <p class="text-sm font-medium text-slate-500">
                {t("ecommerceGuide.technicalSpeed.lcp.desc")}
              </p>
            </div>
            
            <div class="rounded-3xl lg:rounded-[2.5rem] border border-slate-100 bg-slate-50 p-6 lg:p-10">
              <div class="mb-4 lg:mb-6 flex items-center gap-3 lg:gap-4">
                <div class="rounded-xl bg-rose-100 p-2 lg:p-3 text-rose-600">
                  <Zap size={24} />
                </div>
                <h4 class="font-black text-slate-900">{t("ecommerceGuide.technicalSpeed.inp.title")}</h4>
              </div>
              <span class="mb-2 block text-2xl lg:text-3xl font-black text-slate-900">
                {t("ecommerceGuide.technicalSpeed.inp.value")}
              </span>
              <p class="text-sm font-medium text-slate-500">
                {t("ecommerceGuide.technicalSpeed.inp.desc")}
              </p>
            </div>
            
            <div class="rounded-3xl lg:rounded-[2.5rem] border border-slate-100 bg-slate-50 p-6 lg:p-10">
              <div class="mb-4 lg:mb-6 flex items-center gap-3 lg:gap-4">
                <div class="rounded-xl bg-amber-100 p-2 lg:p-3 text-amber-600">
                  <Sparkles size={24} />
                </div>
                <h4 class="font-black text-slate-900">{t("ecommerceGuide.technicalSpeed.cls.title")}</h4>
              </div>
              <span class="mb-2 block text-2xl lg:text-3xl font-black text-slate-900">
                {t("ecommerceGuide.technicalSpeed.cls.value")}
              </span>
              <p class="text-sm font-medium text-slate-500">
                {t("ecommerceGuide.technicalSpeed.cls.desc")}
              </p>
            </div>
          </div>

          <div class="relative overflow-hidden rounded-3xl lg:rounded-[3rem] bg-blue-600 p-8 lg:p-16 text-white">
            <div class="relative z-10 max-w-2xl">
              <h3 class="mb-4 lg:mb-6 flex items-center gap-3 text-xl lg:text-2xl font-black">
                <TrendingUp className="text-blue-200" /> {t("ecommerceGuide.technicalSpeed.proTip.title")}
              </h3>
              <p class="mb-6 lg:mb-8 text-lg lg:text-xl leading-relaxed font-medium text-blue-100">
                {t("ecommerceGuide.technicalSpeed.proTip.description").split("lean stack of 6–10 high-value apps")[0]}
                <strong class="text-white underline decoration-blue-400">
                  lean stack of 6–10 high-value apps
                </strong>{" "}
                {t("ecommerceGuide.technicalSpeed.proTip.description").split("lean stack of 6–10 high-value apps")[1]}
              </p>
              <a
                href={localePath(lang, "/blog/shopify-site-speed-social-proof")}
                class="inline-flex h-12 items-center rounded-full bg-white px-8 text-sm font-black text-blue-600 transition-all hover:bg-slate-100"
              >
                {t("ecommerceGuide.technicalSpeed.proTip.cta")}
              </a>
            </div>
            <BarChart3
              className="absolute -right-20 -bottom-20 h-96 w-96 text-white/10"
              strokeWidth={1}
            />
          </div>
        </div>
      </Section>

      {/* Psychological Trust */}
      <Section className="bg-slate-50/50 py-12 lg:py-24">
        <div class="section-container">
          <div class="flex flex-col items-center gap-12 lg:gap-20 lg:flex-row">
            <div class="lg:w-1/2">
              <h2 class="mb-6 lg:mb-8 text-3xl lg:text-4xl font-black text-slate-900">
                {t("ecommerceGuide.psychologicalTrust.title")}
              </h2>
              <p class="mb-8 lg:mb-10 text-lg lg:text-xl leading-relaxed font-medium text-slate-600">
                {t("ecommerceGuide.psychologicalTrust.description")}
              </p>
              <div class="space-y-4 lg:space-y-6">
                <div class="flex gap-4 lg:gap-6 rounded-2xl lg:rounded-3xl border border-slate-100 bg-white p-6 lg:p-8 shadow-sm transition-all hover:border-blue-500/20">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-lg font-black text-blue-600">
                    {t("ecommerceGuide.psychologicalTrust.lift.value")}
                  </div>
                  <div>
                    <h4 class="mb-2 font-black text-slate-900">
                      {t("ecommerceGuide.psychologicalTrust.lift.title")}
                    </h4>
                    <p class="font-medium text-slate-500">
                      {t("ecommerceGuide.psychologicalTrust.lift.desc")}
                    </p>
                  </div>
                </div>
                
                <div class="flex gap-4 lg:gap-6 rounded-2xl lg:rounded-3xl border border-slate-100 bg-white p-6 lg:p-8 shadow-sm transition-all hover:border-rose-500/20">
                  <div class="flex h-10 w-10 lg:h-12 lg:w-12 shrink-0 items-center justify-center rounded-xl lg:rounded-2xl bg-rose-50 text-base lg:text-lg font-black text-rose-600">
                    {t("ecommerceGuide.psychologicalTrust.threshold.value")}
                  </div>
                  <div>
                    <h4 class="mb-2 font-black text-slate-900">
                      {t("ecommerceGuide.psychologicalTrust.threshold.title")}
                    </h4>
                    <p class="font-medium text-slate-500">
                      {t("ecommerceGuide.psychologicalTrust.threshold.desc")}
                    </p>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="flex flex-col items-center rounded-3xl lg:rounded-[3rem] border border-slate-100 bg-white p-8 lg:p-12 text-center lg:w-1/2">
              <div class="mb-6 lg:mb-8 rounded-full bg-slate-50 p-4 lg:p-6">
                <Sparkles className="h-12 w-12 lg:h-16 lg:w-16 text-amber-500" />
              </div>
              <h3 class="mb-4 lg:mb-6 text-2xl lg:text-3xl font-black text-slate-900">
                {t("ecommerceGuide.psychologicalTrust.visualTrust.title")}
              </h3>
              <p class="mb-6 lg:mb-8 text-base lg:text-lg leading-relaxed font-medium text-slate-500">
                {t("ecommerceGuide.psychologicalTrust.visualTrust.description").split("137%")[0]}
                <strong class="text-blue-600">137%</strong>
                {t("ecommerceGuide.psychologicalTrust.visualTrust.description").split("137%")[1]}.
              </p>
              <a
                href={localePath(lang, "/blog/best-social-proof-apps-shopify-2026")}
                class="flex items-center gap-2 font-black text-blue-600 underline-offset-4 hover:underline"
              >
                {t("ecommerceGuide.psychologicalTrust.visualTrust.cta")} <MousePointer2 size={16} />
              </a>
            </div>
          </div>
        </div>
      </Section>

      {/* Frictionless Conversion */}
      <Section className="py-12 lg:py-24">
        <div class="section-container">
          <div class="mx-auto mb-12 lg:mb-20 max-w-3xl text-center">
            <h2 class="mb-6 lg:mb-8 text-3xl lg:text-5xl font-black text-slate-900">
              {t("ecommerceGuide.frictionlessConversion.title")}
            </h2>
            <p class="text-lg lg:text-xl font-medium text-slate-500">
              {t("ecommerceGuide.frictionlessConversion.description")}
            </p>
          </div>
          <div class="grid grid-cols-1 gap-6 lg:gap-8 md:grid-cols-3">
            <div class="rounded-3xl lg:rounded-[3rem] bg-slate-900 p-8 lg:p-12 text-white">
              <h4 class="mb-4 lg:mb-6 text-xl lg:text-2xl font-black">
                {t("ecommerceGuide.frictionlessConversion.stickyCart.title")}
              </h4>
              <p class="mb-10 leading-relaxed font-medium text-slate-400">
                {t("ecommerceGuide.frictionlessConversion.stickyCart.desc")}
              </p>
              <a
                href={localePath(lang, "/blog/mobile-sticky-cart-guide")}
                class="font-black text-blue-400 hover:underline"
              >
                {t("ecommerceGuide.frictionlessConversion.stickyCart.cta")}
              </a>
            </div>
            
            <div class="rounded-3xl lg:rounded-[3rem] border border-slate-100 bg-slate-50 p-8 lg:p-12">
              <h4 class="mb-4 lg:mb-6 text-xl lg:text-2xl font-black text-slate-900">
                {t("ecommerceGuide.frictionlessConversion.threeClickRule.title")}
              </h4>
              <p class="mb-10 leading-relaxed font-medium text-slate-500">
                {t("ecommerceGuide.frictionlessConversion.threeClickRule.desc")}
              </p>
            </div>
            
            <div class="rounded-3xl lg:rounded-[3rem] bg-blue-600 p-8 lg:p-12 text-white">
              <h4 class="mb-4 lg:mb-6 text-xl lg:text-2xl font-black">{t("ecommerceGuide.frictionlessConversion.urgencyNudges.title")}</h4>
              <p class="mb-10 leading-relaxed font-medium text-blue-100">
                {t("ecommerceGuide.frictionlessConversion.urgencyNudges.desc")}
              </p>
            </div>
          </div>
        </div>
      </Section>

      {/* FAQ Section */}
      <Section className="border-y border-slate-100 bg-slate-50/30 py-12 lg:py-24">
        <div class="section-container max-w-4xl">
          <h2 class="mb-10 lg:mb-16 text-center text-3xl lg:text-4xl font-black text-slate-900">
            {t("ecommerceGuide.faq.headline")}
          </h2>
          <div class="space-y-6 lg:space-y-8">
            {faqItems.map((faq: any) => (
              <div class="rounded-2xl lg:rounded-3xl border border-slate-100 bg-white p-6 lg:p-10 transition-all hover:border-blue-500/20">
                <h4 class="mb-3 lg:mb-4 text-lg lg:text-xl font-black text-slate-900">
                  {faq.question}
                </h4>
                <p class="leading-relaxed font-medium text-slate-500">
                  {faq.answer}
                </p>
              </div>
            ))}
          </div>
        </div>
        <FAQSchema items={faqItems} />
      </Section>

      {/* CTA Anchor for FomoGen */}
      <Section className="py-16 lg:py-32">
        <div class="section-container">
          <div class="relative overflow-hidden rounded-3xl lg:rounded-[4rem] bg-blue-600 p-8 lg:p-24 text-center text-white shadow-2xl">
            <div class="relative z-10">
              <h2 class="mb-6 lg:mb-8 text-4xl sm:text-5xl lg:text-6xl font-black tracking-tighter">
                {t("ecommerceGuide.cta.headline")}
              </h2>
              <p class="mx-auto mb-8 lg:mb-12 max-w-2xl text-lg lg:text-xl font-medium text-blue-100">
                {t("ecommerceGuide.cta.description")}
              </p>
              <div class="flex flex-col items-center justify-center gap-6 sm:flex-row">
                <a
                  href="https://apps.shopify.com/fomogen"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex h-16 items-center rounded-full bg-white px-12 text-lg font-black text-blue-600 shadow-xl transition-all hover:bg-slate-50"
                >
                  {t("ecommerceGuide.cta.primary")}
                </a>
                <a
                  href={localePath(lang, "/about")}
                  class="inline-flex h-16 items-center rounded-full bg-blue-700 px-12 text-lg font-black text-white transition-all hover:bg-blue-800"
                >
                  {t("ecommerceGuide.cta.secondary")}
                </a>
              </div>
            </div>
            {/* Decorative Mesh */}
            <div
              class="pointer-events-none absolute inset-0 z-0 opacity-10"
              style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 4rem 4rem;"
            />
          </div>
        </div>
      </Section>
    </main>

    <Footer />
  </div>
</Layout>
