---
import DocsLayout from '@/layouts/DocsLayout.astro';
import Content from '../components/docs-content/page';
import { i18nConfig } from '@/i18n/config';
import { localize } from '@/i18n/localize';

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;

const meta = {
  title: localize("Documentation Hub | AppLass"),
  description: localize("Comprehensive guides, technical documentation, and integration instructions for the entire AppLass app ecosystem."),
  ogTitle: localize("AppLass Documentation Hub"),
  ogDescription: localize("Technical references and deployment guides for AppLass logic systems.")
};
---

<DocsLayout 
  lang={lang as string} 
  app="hub"
  title={meta.title}
  description={meta.description}
>
  <Content lang={lang as string} />
</DocsLayout>
