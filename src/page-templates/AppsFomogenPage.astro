---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import FomoGenHero from "@/components/apps/fomogen/FomoGenHero.astro";
import SpeedBenefitSection from "@/components/apps/fomogen/SpeedBenefitSection.astro";
import CoreFeatures from "@/components/apps/fomogen/CoreFeatures.astro";
import TestimonialsSection from "@/components/apps/fomogen/TestimonialsSection.astro";
import PricingSection from "@/components/apps/fomogen/PricingSection.astro";
import PricingMatrix from "@/components/apps/fomogen/PricingMatrix.astro";
import FomoGenCTA from "@/components/apps/fomogen/FomoGenCTA.astro";
import FAQRegistrySection from "@/components/common/FAQRegistrySection.astro";
import { getDictionary } from "@/i18n/get-dictionary";
import { i18nConfig } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;
const dict = await getDictionary(lang as any);
const t = useTranslations(dict);

const meta = t('metadata.fomogen') || {};

// Remove featuresData processing as CoreFeatures will handle it directly

---

<Layout 
  title={meta.title || "FOMO Gen: Fast Shopify Social Proof App [No Code 2026]"}
  description={meta.description || "Add high-converting sales popups, countdowns, and sticky carts to Shopify. Zero impact on Core Web Vitals with our 2KB payload."}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <div class="bg-white">
    <Navbar    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            name: "FOMO Gen - Elite Social Proof",
            operatingSystem: "Shopify",
            applicationCategory: "BusinessApplication",
            aggregateRating: {
              "@type": "AggregateRating",
              ratingValue: "4.9",
              ratingCount: "135",
            },
            offers: {
              "@type": "Offer",
              price: "0",
              priceCurrency: "USD",
              priceValidUntil: "2026-12-31",
              availability: "https://schema.org/InStock",
            },
            featureList: t('fomogen.features')?.map((f: any) => f.title).join(", ") || "",
            screenshot: "https://applass.com/fomogen-screenshot.png",
            image: "https://applass.com/fomogen-feature.png",
            description: t('metadata.schema.fomogenDescription') || "FOMO Gen is an all-in-one Shopify app for social proof, urgency, and trust signals.",
            author: {
              "@type": "Organization",
              name: "Applass",
              url: "https://applass.com",
            },
          },
          {
            "@context": "https://schema.org",
            "@type": "Product",
            name: "FOMO Gen",
            description: t('metadata.fomogen.description') || "All-in-one Shopify app for Sales Popups, Stock Countdowns, Sticky Cart, and Trust Badges.",
            brand: {
              "@type": "Brand",
              name: "AppLass",
            },
            offers: {
              "@type": "Offer",
              price: "0.00",
              priceCurrency: "USD",
              priceValidUntil: "2026-12-31",
              availability: "https://schema.org/InStock",
              url: "https://applass.com/apps/fomogen",
            },
          },
        ],
      })}
    />

    <div class="flex-1 overflow-x-hidden">
      <FomoGenHero />
      <SpeedBenefitSection />
      <CoreFeatures />
      <TestimonialsSection />
      <PricingSection />
      <PricingMatrix />
      <FomoGenCTA />
      <FAQRegistrySection
        client:idle
        registryKey="FOMOGEN"
        variant="centered"
        className="bg-white py-24"
        items={t('fomogen.faq.questions')}
        title={t('fomogen.faq.headline')}
        subtitle={t('fomogen.faq.sectionLabel')}
      />
    </div>

    <Footer  />
  </div>
</Layout>
