---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import FomoGenHero from "@/components/apps/fomogen/FomoGenHero.astro";
import SpeedBenefitSection from "@/components/apps/fomogen/SpeedBenefitSection.astro";
import CoreFeatures from "@/components/apps/fomogen/CoreFeatures.astro";
import TestimonialsSection from "@/components/apps/fomogen/TestimonialsSection.astro";
import PricingSection from "@/components/apps/fomogen/PricingSection.astro";
import PricingMatrix from "@/components/apps/fomogen/PricingMatrix.astro";
import FomoGenCTA from "@/components/apps/fomogen/FomoGenCTA.astro";
import FAQRegistrySection from "@/components/common/FAQRegistrySection.astro";
import { localize } from "@/i18n/localize";
import { i18nConfig } from "@/i18n/config";

interface Props {
  lang: typeof i18nConfig.locales[number];
}
const { lang } = Astro.props;

import { getFomoGenData } from "@/constants/fomogen-data";

const fomoData = getFomoGenData();

const meta = {
  title: localize("FOMO Gen | #1 Free Social Proof, Urgency & Trust App for Shopify"),
  description: localize("Skyrocket your Shopify sales with FOMO Gen. The all-in-one app for Sales Popups, Stock Countdowns, Sticky Cart, and Trust Badges. Install for Free today!"),
  keywords: localize("shopify social proof, sales pop, countdown timer, stock alert, trust badges, sticky cart"),
  ogTitle: localize("Boost Your Shopify Sales with FOMO Gen"),
  ogDescription: localize("The all-in-one app for Sales Popups, Stock Countdowns, Sticky Cart, and Trust Badges. Install for Free today!"),
  ogImage: "https://applass.com/fomogen-feature.png",
  ogUrl: "https://applass.com/apps/fomogen"
};

---

<Layout 
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <div class="bg-white">
    <Navbar    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            name: "FOMO Gen - Elite Social Proof",
            operatingSystem: "Shopify",
            applicationCategory: "BusinessApplication",
            aggregateRating: {
              "@type": "AggregateRating",
              ratingValue: "4.9",
              ratingCount: "135",
            },
            offers: {
              "@type": "Offer",
              price: "0",
              priceCurrency: "USD",
              priceValidUntil: "2026-12-31",
              availability: "https://schema.org/InStock",
            },
            featureList: fomoData.features.map((f) => f.title).join(", "),
            screenshot: "https://applass.com/fomogen-screenshot.png",
            image: "https://applass.com/fomogen-feature.png",
            description: localize("FOMO Gen is an all-in-one Shopify app for social proof, urgency, and trust signals."),
            author: {
              "@type": "Organization",
              name: localize("Applass"),
              url: "https://applass.com",
            },
          },
          {
            "@context": "https://schema.org",
            "@type": "Product",
            name: localize("FOMO Gen"),
            description: localize("All-in-one Shopify app for Sales Popups, Stock Countdowns, Sticky Cart, and Trust Badges."),
            brand: {
              "@type": "Brand",
              name: localize("AppLass"),
            },
            offers: {
              "@type": "Offer",
              price: "0.00",
              priceCurrency: "USD",
              priceValidUntil: "2026-12-31",
              availability: "https://schema.org/InStock",
              url: "https://applass.com/apps/fomogen",
            },
          },
        ],
      })}
    />

    <div class="flex-1 overflow-x-hidden">
      <FomoGenHero />
      <SpeedBenefitSection />
      <CoreFeatures />
      <TestimonialsSection />
      <PricingSection />
      <PricingMatrix />
      <FomoGenCTA />
      <FAQRegistrySection
        registryKey="FOMOGEN"
        variant="centered"
        className="bg-white py-24"
      />
    </div>

    <Footer  />
  </div>
</Layout>
