---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import PricingSection from "@/components/apps/fomogen/PricingSection.astro";
import { i18nConfig } from "@/i18n/config";
import { localize } from "@/i18n/localize";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;

const meta = {
  title: localize("FOMO Gen Pricing | Elite Social Proof for Shopify"),
  description: localize("Transparent, performance-based pricing for AppLass FOMO Gen. No bait-and-switch. 100% ROI guarantee.")
};

---

<Layout 
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <div class="bg-white">
    <Navbar    />
    
    <div class="pt-32 pb-0">
      <PricingSection />
    </div>

    <Footer />
  </div>
</Layout>
