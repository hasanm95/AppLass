---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import { PricingSection } from "@/components/apps/fomogen/PricingSection";
import { getDictionary } from "@/i18n/get-dictionary";
import { i18nConfig } from "@/i18n/config";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;
const dict = await getDictionary(lang as any);

const meta = dict.metadata?.fomogenPricing || {};

---

<Layout 
  title={meta.title || "FOMO Gen Pricing | Elite Social Proof for Shopify"}
  description={meta.description || "Transparent, performance-based pricing for AppLass FOMO Gen. No bait-and-switch. 100% ROI guarantee."}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <div class="bg-white">
    <Navbar    />
    
    <div class="pt-32 pb-0">
      <PricingSection translations={dict.fomogen?.pricing} />
    </div>

    <Footer />
  </div>
</Layout>
