---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import ScreenVeilHero from "@/components/apps/screenveil/ScreenVeilHero.astro";
import PainPointsSection from "@/components/apps/screenveil/PainPointsSection.astro";
import FeatureGrid from "@/components/apps/screenveil/FeatureGrid.astro";
import TechnicalAdvantage from "@/components/apps/screenveil/TechnicalAdvantage.astro";
import PrivacySection from "@/components/apps/screenveil/PrivacySection.astro";
import TestimonialsSection from "@/components/apps/screenveil/TestimonialsSection.astro";
import FAQSection from "@/components/apps/screenveil/FAQSection.astro";
import CompetitorComparison from "@/components/apps/screenveil/CompetitorComparison.astro";
import ScreenVeilClosingCTA from "@/components/apps/screenveil/ScreenVeilClosingCTA.astro";
import { StickyDownloadBar } from "@/components/apps/screenveil/StickyDownloadBar";
import { getScreenveilData, getScreenveilSchema } from "@/constants/screenveil-data";
import { i18nConfig } from "@/i18n/config";
import { localize } from "@/i18n/localize";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;

import { setLocale } from "@/i18n";
setLocale(lang);

const isDefault = lang === "en";
const lastUpdated = "2026-03-23";
const screenveilData = getScreenveilData();
const screenveilSchema = {
  ...getScreenveilSchema(),
  "datePublished": "2023-11-20",
  "dateModified": lastUpdated,
  "author": {
    "@type": "Person",
    "name": "Hasan M.",
    "jobTitle": "Founder & Lead Engineer",
    "url": "https://applass.com/about"
  }
};

const meta = {
  title: "Play YouTube With Screen Off – AMOLED Battery Saver | ScreenVeil",
  description: "ScreenVeil saves 60%+ battery on AMOLED/OLED Android devices. Play YouTube, podcasts & music with your screen off. Zero permissions. 10,000+ downloads. Free.",
  keywords: localize("black screen video, AMOLED battery saver, screen off playback, YouTube background audio, OLED efficiency, screen overlay utility, android battery saver, screen off youtube"),
  ogTitle: localize("ScreenVeil: Save 60% Battery with Screen Off Video Playback"),
  ogDescription: localize("The ultimate AMOLED battery saver. Watch YouTube, Netflix, and podcasts with your screen off. Zero permissions, 100% privacy."),
  ogImage: "https://applass.com/screenveil-feature.png",
  ogUrl: isDefault ? "https://applass.com/apps/screenveil" : `https://applass.com/${lang}/apps/screenveil`
};

---

<Layout 
  title={meta.title || "ScreenVeil: The Safest Screen Filter for Total Digital Privacy"}
  description={meta.description || "Protect your data from prying eyes with ScreenVeil. A lightweight, secure screen overlay for Android. No data collection, 100% offline."}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <div class="bg-[#020617]">
    <Navbar   variant='dark'  />

    <div class="flex-1 overflow-x-hidden">
      {/* SoftwareApplication Schema for SEO - triggers rich results with star ratings */}
      <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(screenveilSchema)}
      />
      <ScreenVeilHero>
        <div slot="meta" class="mb-6 flex items-center justify-center lg:justify-start gap-4">
          <span class="rounded-full bg-green-500/10 px-3 py-1 text-[10px] font-bold text-green-400 uppercase border border-green-500/20 backdrop-blur-md">
            {localize("Last Evaluated: ")} {lastUpdated}
          </span>
          <span class="h-1 w-1 rounded-full bg-slate-800"></span>
          <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest italic">
            {localize("AMOLED Optimization Verified")}
          </span>
        </div>

        <div slot="ai-summary" class="mt-10 overflow-hidden rounded-2xl border border-green-500/20 bg-slate-900/50 backdrop-blur-xl text-left shadow-2xl">
          <div class="bg-green-500 px-4 py-2 text-[9px] font-black tracking-widest text-black uppercase flex items-center justify-between">
            <span>{localize("App Protocol Summary (TL;DR)")}</span>
            <span class="text-slate-900 font-mono">[ SV.V4_STABLE ]</span>
          </div>
          <div class="grid grid-cols-1 gap-px bg-slate-800 md:grid-cols-3">
            <div class="bg-slate-900 p-4">
              <p class="mb-1 text-[9px] font-bold text-slate-500 uppercase tracking-tighter">{localize("Benchmark")}</p>
              <p class="font-black text-white text-sm">{localize("60%+ Battery Saving")}</p>
            </div>
            <div class="bg-slate-900 p-4">
              <p class="mb-1 text-[9px] font-bold text-slate-500 uppercase tracking-tighter">{localize("Privacy")}</p>
              <p class="font-black text-white text-sm">{localize("Zero Permissions")}</p>
            </div>
            <div class="bg-slate-900 p-4">
              <p class="mb-1 text-[9px] font-bold text-slate-500 uppercase tracking-tighter">{localize("Tech")}</p>
              <p class="font-black text-white text-sm">{localize("AMOLED Optimized")}</p>
            </div>
          </div>
        </div>
      </ScreenVeilHero>
      <PainPointsSection />
      <FeatureGrid />
      <TechnicalAdvantage />
      <PrivacySection />
      <TestimonialsSection />
      <CompetitorComparison />
      <FAQSection />
      <ScreenVeilClosingCTA />
    </div>

    <Footer variant="dark" />
    <StickyDownloadBar client:idle translations={screenveilData.hero} />
  </div>
</Layout>
