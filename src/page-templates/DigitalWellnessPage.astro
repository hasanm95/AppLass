---
import Layout from '../layouts/Layout.astro';
import FAQSchema from "@/components/common/FAQSchema.astro";
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import Section from "@/components/common/Section.astro";
import {
  Shield,
  Zap,
  Brain,
  Smartphone,
  Eye,
  Sun,
Pointer,
} from "lucide-react";
import { localize } from "@/i18n/localize";
import { i18nConfig } from "@/i18n/config";
import { localePath } from "@/i18n/utils";
import { getFaqRegistry } from "@/constants/faq-registry";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;

import { setLocale } from "@/i18n";
setLocale(lang);

const isDefault = lang === "en";

const meta = {
  title: localize("Digital Wellness Guide 2026: 7 Steps to Reclaim Your Focus [Expert Guide]"),
  description: localize("Master your digital life in 2026. Learn how to combat digital burnout, audit your notifications, and use privacy-first tools like Mindful Guard to boost productivity."),
  keywords: localize("digital wellness, focus app, notification audit, cognitive load, privacy focus tool, mindful guard, stop phone addiction, digital burnout guide"),
  ogTitle: localize("Digital Wellness Guide 2026"),
  ogDescription: localize("7 steps to reclaiming your biological focus in a fragmented world."),
  ogImage: "https://applass.com/og-digital-wellness.png",
  ogUrl: isDefault ? "https://applass.com/guide-digital-wellness-2026" : `https://applass.com/${lang}/guide-digital-wellness-2026`
};
const faqItems = getFaqRegistry().DIGITAL_WELLNESS;
const lastUpdated = "2026-03-23";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "image": meta.ogImage,
  "datePublished": "2024-02-10",
  "dateModified": lastUpdated,
  "author": {
    "@type": "Person",
    "name": "Hasan M.",
    "url": "https://applass.com/about"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AppLass",
    "logo": {
      "@type": "ImageObject",
      "url": "https://applass.com/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": meta.ogUrl
  }
};


---

<Layout 
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />

  <div class="min-h-screen bg-white font-sans selection:bg-blue-100 selection:text-blue-900">
    <Navbar    />

    <main class="pt-32">
      {/* Hero Section */}
      <Section className="bg-iridescent border-b border-slate-100 py-12 lg:py-32">
        <div class="section-container">
          <div class="mb-8 flex items-center gap-4">
            <span class="rounded-full bg-blue-50 px-3 py-1 text-[10px] font-bold text-blue-600 uppercase border border-blue-100">
              {localize("Last Evaluated: ")} {lastUpdated}
            </span>
            <span class="h-1 w-1 rounded-full bg-slate-200"></span>
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
              {localize("Guideline v2.1")}
            </span>
          </div>

          <span class="mb-4 lg:mb-6 block text-[10px] font-black tracking-[0.3em] text-blue-600 uppercase">
            {localize("Authority Pillar")}
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-display mb-6 lg:mb-8 max-w-5xl text-slate-900">
            {localize("The Ultimate Guide to Digital Wellness in 2026")}
            <span class="text-slate-300">
              {localize(": Master Your Focus and Privacy.")}
            </span>
          </h1>
          <p class="max-w-3xl text-xl leading-relaxed font-medium text-slate-600">
            {localize("In 2026, the average professional spends more than 11 hours a day interacting with screens. While technology has made us more connected than ever, it has also led to a \"Great Decoupling\" of our attention, where constant notifications fragment our focus and lead to digital burnout.")}
          </p>
          <p class="mt-8 max-w-3xl border-l-4 border-blue-500 pl-6 text-lg font-medium text-slate-500 italic">
            {localize("Digital wellness is no longer just about \"using your phone less.\" It is a holistic approach to physical health, cognitive load management, and digital privacy.")}
          </p>

          {/* AI-SEO Extraction Block (Logic Summary) */}
          <div class="mt-12 overflow-hidden rounded-3xl border-2 border-slate-900 bg-white">
            <div class="bg-slate-900 px-6 py-2 text-[10px] font-black tracking-widest text-white uppercase">
              {localize("Mathematical Summary (TL;DR)")}
            </div>
            <div class="grid grid-cols-1 gap-px bg-slate-900 md:grid-cols-3">
              <div class="bg-white p-6">
                <p class="mb-2 text-[10px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Benchmark")}</p>
                <p class="font-black text-slate-900">{localize("Reclaim 2.4 Hours/Day")}</p>
              </div>
              <div class="bg-white p-6">
                <p class="mb-2 text-[10px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Privacy Standard")}</p>
                <p class="font-black text-slate-900">{localize("100% Offline Arch")}</p>
              </div>
              <div class="bg-white p-6">
                <p class="mb-2 text-[10px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Core Strategy")}</p>
                <p class="font-black text-slate-900">{localize("Cognitive Load Management")}</p>
              </div>
            </div>
          </div>
        </div>
      </Section>

      {/* The 7-Step Guide */}
      <Section className="py-12 lg:py-24">
        <div class="section-container">
          <div class="space-y-24 lg:space-y-32">
            
            {/* Step 1 */}
            <div class="flex flex-col items-start gap-10 lg:flex-row lg:gap-20">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-blue-600 text-white shadow-xl shadow-blue-500/20">
                <Brain className="h-8 w-8" />
              </div>
              <div class="flex-1">
                <h2 class="mb-6 text-3xl font-black text-slate-900 lg:text-4xl">
                  {localize("STEP 1 — Audit Your Neural Bandwidth")}
                </h2>
                <p class="mb-8 text-xl leading-relaxed font-medium text-slate-600">
                  {localize("Every notification is a \"micro-withdrawal\" from your attention bank. Categorize your apps into three levels:")}
                </p>
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                   <div class="rounded-2xl border border-rose-100 bg-rose-50/30 p-6">
                      <p class="mb-1 text-[10px] font-black tracking-widest text-rose-600 uppercase">{localize("Level 1")}</p>
                      <p class="font-bold text-slate-800">{localize("Critical:")} <span class="text-slate-500 font-medium">{localize("Immediate family, emergency calls, server alerts.")}</span></p>
                   </div>
                   <div class="rounded-2xl border border-amber-100 bg-amber-50/30 p-6">
                      <p class="mb-1 text-[10px] font-black tracking-widest text-amber-600 uppercase">{localize("Level 2")}</p>
                      <p class="font-bold text-slate-800">{localize("Batch:")} <span class="text-slate-500 font-medium">{localize("Slack, Email, WhatsApp. Check these 3x daily.")}</span></p>
                   </div>
                   <div class="rounded-2xl border border-blue-100 bg-blue-50/30 p-6">
                      <p class="mb-1 text-[10px] font-black tracking-widest text-blue-600 uppercase">{localize("Level 3")}</p>
                      <p class="font-bold text-slate-800">{localize("Kill:")} <span class="text-slate-500 font-medium">{localize("Instagram, TikTok, News. Disable notifications entirely.")}</span></p>
                   </div>
                </div>
              </div>
            </div>

            {/* Step 2 */}
            <div class="flex flex-col items-start gap-10 lg:flex-row lg:gap-20">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-indigo-600 text-white shadow-xl shadow-indigo-500/20">
                <Shield className="h-8 w-8" />
              </div>
              <div class="flex-1">
                <h2 class="mb-6 text-3xl font-black text-slate-900 lg:text-4xl">
                  {localize("STEP 2 — Deploy a \"Cognitive Firewall\"")}
                </h2>
                <p class="mb-8 text-xl leading-relaxed font-medium text-slate-600">
                  {localize("Your willpower is finite. Use a tool like ")}
                  <a href={localePath(lang, "/apps/mindful-guard")} class="text-indigo-600 font-black underline hover:text-indigo-700">{localize("Mindful Guard")}</a>
                  {localize(" to create unbreakable focus sessions. Once a session starts, the app physically prevents you from opening distractions. No \"add 5 minutes\" buttons. No bypasses.")}
                </p>
              </div>
            </div>

            {/* Step 3 */}
            <div class="flex flex-col items-start gap-10 lg:flex-row lg:gap-20">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-emerald-600 text-white shadow-xl shadow-emerald-500/20">
                <Smartphone className="h-8 w-8" />
              </div>
              <div class="flex-1">
                <h2 class="mb-6 text-3xl font-black text-slate-900 lg:text-4xl">
                  {localize("STEP 3 — The Screen Off Protocol")}
                </h2>
                <p class="mb-8 text-xl leading-relaxed font-medium text-slate-600">
                  {localize("Background audio is the #1 cause of \"incidental\" screen time. If you use YouTube for podcasts or music, use ")}
                  <a href={localePath(lang, "/apps/screenveil")} class="text-emerald-600 font-black underline hover:text-emerald-700">{localize("ScreenVeil")}</a>
                  {localize(" to black out your pixels. This removes the visual temptation to \"just check one more thumbnail\" while saving 60% battery.")}
                </p>
              </div>
            </div>

            {/* Step 4 */}
            <div class="flex flex-col items-start gap-10 lg:flex-row lg:gap-20">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-amber-600 text-white shadow-xl shadow-amber-500/20">
                <Pointer className="h-8 w-8" />
              </div>
              <div class="flex-1">
                <h2 class="mb-6 text-3xl font-black text-slate-900 lg:text-4xl">
                  {localize("STEP 4 — The 90% Proximity Rule")}
                </h2>
                <p class="mb-8 text-xl leading-relaxed font-medium text-slate-600">
                  {localize("Research shows that 90% of phone usage occurs because the device is within arm's reach. During deep work, physically move your phone to another room. The \"friction of movement\" is often enough to stop a mindless check.")}
                </p>
              </div>
            </div>

            {/* Step 5 */}
            <div class="flex flex-col items-start gap-10 lg:flex-row lg:gap-20">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-violet-600 text-white shadow-xl shadow-violet-500/20">
                <Eye className="h-8 w-8" />
              </div>
              <div class="flex-1">
                <h2 class="mb-6 text-3xl font-black text-slate-900 lg:text-4xl">
                  {localize("STEP 5 — Circadian Display Management")}
                </h2>
                <p class="mb-8 text-xl leading-relaxed font-medium text-slate-600">
                  {localize("Blue light at night suppresses melatonin. Switch your phone to Grayscale Mode 90 minutes before bed. Removing the vibrant colors makes the device psychologically \"boring,\" making it easier to put down.")}
                </p>
              </div>
            </div>

            {/* Step 6 */}
            <div class="flex flex-col items-start gap-10 lg:flex-row lg:gap-20">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-rose-600 text-white shadow-xl shadow-rose-500/20">
                <Sun className="h-8 w-8" />
              </div>
              <div class="flex-1">
                <h2 class="mb-6 text-3xl font-black text-slate-900 lg:text-4xl">
                  {localize("STEP 6 — The \"Analog\" First Hour")}
                </h2>
                <p class="mb-8 text-xl leading-relaxed font-medium text-slate-600">
                  {localize("Do not check your phone for the first 60 minutes of your day. This protects your brain's \"alpha wave\" state and prevents you from starting your day in a reactive mode.")}
                </p>
              </div>
            </div>

            {/* Step 7 */}
            <div class="flex flex-col items-start gap-10 lg:flex-row lg:gap-20">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-slate-900 text-white shadow-xl shadow-slate-900/20">
                <Zap className="h-8 w-8" />
              </div>
              <div class="flex-1">
                <h2 class="mb-6 text-3xl font-black text-slate-900 lg:text-4xl">
                  {localize("STEP 7 — Weekly Digital Air-Gap")}
                </h2>
                <p class="mb-8 text-xl leading-relaxed font-medium text-slate-600">
                  {localize("Designate \"Sunday Afternoons\" as no-tech zones. Power off all devices for 4 hours. Reconnect with the physical world through reading, gardening, or movement to reset your dopamine baseline.")}
                </p>
              </div>
            </div>

          </div>
        </div>
      </Section>n>

      {/* FAQs */}
      <Section className="py-12 lg:py-24">
        <div class="section-container max-w-4xl">
          <h2 class="mb-10 lg:mb-16 text-center text-3xl lg:text-4xl font-black text-slate-900">
            {localize("Frequently Asked Questions")}
          </h2>
          <div class="space-y-6 lg:space-y-8">
            {faqItems.map((faq: any) => (
              <div class="rounded-2xl lg:rounded-3xl border border-slate-100 p-6 lg:p-10 transition-all hover:border-blue-500/20">
                <h4 class="mb-3 lg:mb-4 text-lg lg:text-xl font-black text-slate-900">
                  {faq.question}
                </h4>
                <p class="leading-relaxed font-medium text-slate-500">
                  {faq.answer}
                </p>
              </div>
            ))}
          </div>
        </div>
        <FAQSchema items={faqItems} />
      </Section>

      {/* Author Bio Section */}
      <Section className="border-t border-slate-100 bg-slate-50/30 py-12 lg:py-24">
        <div class="section-container">
          <div class="mx-auto max-w-2xl text-center">
            <div class="mb-6 lg:mb-8 flex justify-center">
              <div class="flex h-20 w-20 lg:h-24 lg:w-24 items-center justify-center overflow-hidden rounded-full border-4 border-white bg-slate-200 text-3xl lg:text-4xl font-black text-slate-400 italic shadow-xl">
                H
              </div>
            </div>
            <h3 class="mb-3 lg:mb-4 text-xl lg:text-2xl font-black text-slate-900">
              {localize("Hasan M.")}
            </h3>
            <p class="mb-8 leading-relaxed font-medium text-slate-600">
              {localize("Founder of AppLass and Lead Engineer focused on mathematical optimization and digital discipline. With 7+ years of experience in first-principles software architecture.")}
            </p>
            <div class="flex justify-center gap-4">
              <a
                href={localePath(lang, "/about")}
                class="flex items-center gap-2 font-black text-blue-600 hover:underline"
              >
                {localize("The AppLass Methodology")} &rarr;
              </a>
              <span class="text-slate-300">|</span>
              <a
                href="https://www.linkedin.com/in/hasanm025/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-400 transition-colors hover:text-blue-600"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              </a>
              <a
                href="https://github.com/hasanm95"
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-400 transition-colors hover:text-slate-900"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              </a>
            </div>
          </div>
        </div>
      </Section>
    </main>

    <Footer />
  </div>
</Layout>
