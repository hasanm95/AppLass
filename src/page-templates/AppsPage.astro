---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import fomogenFeatureImg from '@/assets/apps/fomogen-feature.png';
import mindfulGuardFeatureImg from '@/assets/apps/mindful-guard-feature.png';
import screenveilFeatureImg from '@/assets/apps/screenveil-feature.png';
import Footer from "@/components/common/Footer.astro";
import SubpageHero from "@/components/common/SubpageHero.astro";
import Navbar from "@/components/common/Navbar.astro";
import { LinkButton } from "@/components/ui/link-button";
import { getProducts } from "@/constants/home-data";
import Section from "@/components/common/Section.astro";
import { localize } from "@/i18n/localize";
import { i18nConfig } from "@/i18n/config";
import { localePath } from "@/i18n/utils";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;

import { setLocale } from "@/i18n";
setLocale(lang);
const isDefault = lang === "en"; 

const meta = {
  title: localize("Our Apps | AppLass Ecosystem"),
  description: localize("Explore our suite of logic-driven applications designed for elite performance and digital discipline."),
  keywords: localize("Shopify apps, Android utilities, focus apps, privacy tools, FomoGen, ScreenVeil, Mindful Guard"),
  ogTitle: localize("Our Apps | AppLass Ecosystem"),
  ogDescription: localize("Explore our suite of logic-driven applications designed for elite performance."),
  ogImage: "https://applass.com/og-apps.png",
  ogUrl: isDefault ? "https://applass.com/apps" : `https://applass.com/${lang}/apps`
};

const imageMap: Record<string, ImageMetadata> = {
  fomogen: fomogenFeatureImg,
  mindful: mindfulGuardFeatureImg,
  screenveil: screenveilFeatureImg,
};

---

<Layout 
  title={meta.title || "Our Apps | AppLass Ecosystem"}
  description={meta.description || "Explore our suite of logic-driven applications designed for elite performance and digital discipline."}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <div class="min-h-screen bg-white">
    <Navbar    />
    <div class="pt-32">
      <SubpageHero
        eyebrow={localize("AppLass Ecosystem")}
        headline={localize("Our")}
        headlineAccent={localize("Ecosystem.")}
        description={localize("Proprietary systems built with technical discipline and a focus on measurable impact. Every tool is a derivation of logic.")}
        centered
      />

      <div class="section-container">
        {/* AI-SEO Extraction Block (Logic Summary) */}
        <div class="mx-auto mt-8 max-w-4xl overflow-hidden rounded-3xl border-2 border-slate-900 bg-white shadow-2xl">
          <div class="bg-slate-900 px-6 py-2 text-[10px] font-black tracking-widest text-white uppercase flex items-center justify-between">
            <span>{localize("Ecosystem Analysis (TL;DR)")}</span>
            <span class="text-blue-400 font-mono">[ SYSTEM.READY ]</span>
          </div>
          <div class="grid grid-cols-1 gap-px bg-slate-900 md:grid-cols-3 text-center">
            <div class="bg-white p-6">
              <p class="mb-2 text-[10px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Registry")}</p>
              <p class="font-black text-slate-900">{localize("3 Core Logic Engines")}</p>
            </div>
            <div class="bg-white p-6">
              <p class="mb-2 text-[10px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Tech Stack")}</p>
              <p class="font-black text-slate-900">{localize("Zero-Telemetry Arch")}</p>
            </div>
            <div class="bg-white p-6">
              <p class="mb-2 text-[10px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Standards")}</p>
              <p class="font-black text-slate-900">{localize("WCAG 2.1 + CWV Safe")}</p>
            </div>
          </div>
        </div>
      </div>

      <Section className="py-24">
        <div class="section-container">
          <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
            {getProducts().map((product) => {
              return (
                <div
                  class="group relative flex flex-col overflow-hidden rounded-[3rem] border border-slate-200 bg-white transition-all hover:border-blue-500/30 hover:shadow-2xl"
                >
                  <div class="aspect-video overflow-hidden bg-slate-50 relative">
                    <Image
                      src={imageMap[product.id] || screenveilFeatureImg}
                      alt={`${product.name} - ${product.tagline}`}
                      width={800}
                      height={450}
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                  </div>

                  <div class="flex flex-1 flex-col p-10 lg:p-12">
                    <div class="mb-6 flex items-center justify-between">
                      <span class="text-[10px] font-black tracking-widest text-blue-800 uppercase">
                        {product.platform}
                      </span>
                      <div class="flex gap-2">
                        {product.metrics.map((metric: string) => (
                          <span
                            class="rounded-full bg-slate-50 px-3 py-1 text-[10px] font-bold text-slate-500"
                          >
                            {metric}
                          </span>
                        ))}
                      </div>
                    </div>

                    <h2 class="mb-4 text-4xl font-black text-slate-900">
                      {product.name}
                    </h2>
                    <p class="mb-8 text-lg leading-relaxed font-medium text-slate-500">
                      {product.description}
                    </p>

                    <div class="mt-auto">
                      <LinkButton
                        href={localePath(lang, `/apps/${product.id === "mindful" ? "mindful-guard" : product.id}`)}
                        className="h-14 w-full rounded-2xl bg-slate-900 text-lg font-bold text-white transition-all hover:bg-blue-600"
                      >
                        {localize("View Product Details")}
                      </LinkButton>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </Section>
    </div>
    <Footer />
  </div>
</Layout>
