---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import Hero from "@/components/home/Hero.astro";
import SocialProof from "@/components/home/SocialProof.astro";
import ProductShowcase from "@/components/home/ProductShowcase.astro";
import FoundersMoat from "@/components/home/FoundersMoat.astro";
import SolutionsSection from "@/components/home/SolutionsSection.astro";
import AnswerNuggets from "@/components/home/AnswerNuggets.astro";
import { i18nConfig } from "@/i18n/config";
import { setLocale } from "@/i18n";
import { localize } from "@/i18n/localize";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;
setLocale(lang);
const meta = {
  title: localize("Applass: Productivity & Privacy Solutions for the 2026 Digital World"),
  description: localize("Home of Mindful Guard and ScreenVeil. Discover advanced Android focus tools and Shopify apps designed to protect your privacy and boost ROI."),
  ogTitle: localize("AppLass | Logic-Driven Software Studio"),
  ogDescription: localize("Mathematical precision meets human-centric design. We build the Next Wave of digital performance.")
};

---

<Layout 
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  lang={lang}
>
  <Navbar    />
  <Hero />
  <SocialProof />
  <ProductShowcase />
  <FoundersMoat />
  <SolutionsSection />
  <AnswerNuggets />
  <Footer />
</Layout>
