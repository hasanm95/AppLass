---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import Hero from "@/components/home/Hero.astro";
import SocialProof from "@/components/home/SocialProof.astro";
import ProductShowcase from "@/components/home/ProductShowcase.astro";
import FoundersMoat from "@/components/home/FoundersMoat.astro";
import SolutionsSection from "@/components/home/SolutionsSection.astro";
import { AnswerNuggets } from "@/components/home";
import { i18nConfig } from "@/i18n/config";
import { setLocale } from "@/i18n";
import { localize } from "@/i18n/localize";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;
setLocale(lang);



---

<Layout 
  title={localize("AppLass: Productivity & Privacy Solutions")}
  description={localize("Home of Mindful Guard and ScreenVeil.")}
  lang={lang}
>
  <Navbar    />
  <Hero />
  <SocialProof />
  <ProductShowcase />
  <FoundersMoat />
  <SolutionsSection />
  <AnswerNuggets />
  <Footer />
</Layout>
