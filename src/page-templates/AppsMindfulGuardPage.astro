---
import Layout from '../layouts/Layout.astro';
import Footer from "@/components/common/Footer.astro";
import Navbar from "@/components/common/Navbar.astro";
import MindfulHero from "@/components/apps/mindful-guard/MindfulHero.astro";
import LogicSection from "@/components/apps/mindful-guard/LogicSection.astro";
import DifferentiatorsSection from "@/components/apps/mindful-guard/DifferentiatorsSection.astro";
import ComparisonMatrix from "@/components/apps/mindful-guard/ComparisonMatrix.astro";
import FAQRegistrySection from "@/components/common/FAQRegistrySection.astro";
import MindfulStatsBar from "@/components/apps/mindful-guard/MindfulStatsBar.astro";
import MindfulPricing from "@/components/apps/mindful-guard/MindfulPricing.astro";
import MindfulClosingCTA from "@/components/apps/mindful-guard/MindfulClosingCTA.astro";
import { getMindfulGuardSchema } from "@/constants/mindful-guard-data";
import { i18nConfig } from "@/i18n/config";
import { localize } from "@/i18n/localize";

interface Props {
  lang: typeof i18nConfig.locales[number];
}

const { lang } = Astro.props;

import { setLocale } from "@/i18n";
setLocale(lang);

const isDefault = lang === "en";
const lastUpdated = "2026-03-23";
const mindfulSchema = {
  ...getMindfulGuardSchema(),
  "datePublished": "2024-02-15",
  "dateModified": lastUpdated,
  "author": {
    "@type": "Person",
    "name": "Hasan M.",
    "jobTitle": "Founder & Lead Engineer",
    "url": "https://applass.com/about"
  }
};

const meta = {
  title: "Mindful Guard: Privacy-First Screen Time App for Android (No Tracking)",
  description: "Mindful Guard blocks distracting apps on Android with zero telemetry and no internet required. 100% on-device. No VPN. Reclaim 2.4 hours of daily focus. Free to download.",
  keywords: localize("Android app blocker, dopamine detox app, focus timer android, privacy focus tool, stop phone addiction, cognitive firewall, zero telemetry, offline app blocker"),
  ogTitle: localize("MindfulGuard | Reclaim Your Neural Architecture"),
  ogDescription: localize("The first Android app blocker engineered for privacy absolutists. 0ms latency. 100% Offline. Zero telemetry."),
  ogImage: "https://applass.com/mindful-guard-feature.png",
  ogUrl: isDefault ? "https://applass.com/apps/mindful-guard" : `https://applass.com/${lang}/apps/mindful-guard`
};

---

<Layout 
  title={meta.title || "Mindful Guard: The #1 Privacy-First Focus App [Android 2026]"}
  description={meta.description || "Stop digital distractions instantly. Mindful Guard is a 100% private, offline Pomodoro and app blocker for Android. Download for free today!"}
  keywords={meta.keywords}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  ogUrl={meta.ogUrl}
  lang={lang}
>
  <Navbar    />
  {/* SoftwareApplication Schema for SEO - Critical for Google to display app details */}
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(mindfulSchema)}
  />
  <div class="flex-1">
    {/* Section 1: The Hero (Above the Fold) */}
    <MindfulHero>
      <div slot="meta" class="mb-6 flex items-center justify-center lg:justify-start gap-4">
        <span class="rounded-full bg-emerald-50 px-3 py-1 text-[10px] font-bold text-emerald-700 uppercase border border-emerald-100 backdrop-blur-md">
          {localize("Last Evaluated: ")} {lastUpdated}
        </span>
        <span class="h-1 w-1 rounded-full bg-slate-200"></span>
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest italic">
          {localize("Privacy Architecture Verified")}
        </span>
      </div>

      <div slot="ai-summary" class="mt-10 overflow-hidden rounded-2xl border border-emerald-900/10 bg-white/50 backdrop-blur-sm text-left shadow-lg">
        <div class="bg-[#064E3B] px-4 py-2 text-[9px] font-black tracking-widest text-white uppercase flex items-center justify-between">
          <span>{localize("App Protocol Summary (TL;DR)")}</span>
          <span class="text-emerald-400 font-mono">[ MG.V2_SECURE ]</span>
        </div>
        <div class="grid grid-cols-1 gap-px bg-emerald-900/10 md:grid-cols-3">
          <div class="bg-white p-4">
            <p class="mb-1 text-[9px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Benchmark")}</p>
            <p class="font-black text-slate-900 text-sm">{localize("+2.4h Daily Focus")}</p>
          </div>
          <div class="bg-white p-4">
            <p class="mb-1 text-[9px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Architecture")}</p>
            <p class="font-black text-slate-900 text-sm">{localize("100% On-Device")}</p>
          </div>
          <div class="bg-white p-4">
            <p class="mb-1 text-[9px] font-bold text-slate-400 uppercase tracking-tighter">{localize("Privacy")}</p>
            <p class="font-black text-slate-900 text-sm">{localize("Zero Telemetry")}</p>
          </div>
        </div>
      </div>
    </MindfulHero>
 
    {/* Stats Bar */}
    <MindfulStatsBar />

    {/* Section 2: The Logic (The "Why" - AI Optimization) */}
    <LogicSection />
 
    {/* Section 3: The Differentiators (The "Moat") */}
    <DifferentiatorsSection />
 
    {/* Section 4: The Comparison Matrix (Conversion Driver) */}
    <ComparisonMatrix />
 
    {/* Pricing Section */}
    <MindfulPricing />

    {/* Section 5: Engineered FAQ (AI Snippet Bait) */}
    <FAQRegistrySection
      registryKey="MINDFUL_GUARD"
      variant="fragmented"
      className="bg-[#FBFBFA]"
    />

    {/* Closing CTA */}
    <MindfulClosingCTA />
  </div>
  <Footer />
</Layout>
